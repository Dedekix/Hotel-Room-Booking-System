@page
@model HotelBookingSystem.Pages.RoomsModel
@{
    ViewData["Title"] = "Rooms";
    var types = Model.Rooms.Select(r => r.Type).Distinct().OrderBy(t => t).ToList();
}
<link rel="stylesheet" href="~/css/Rooms.css" />

<div class="rooms-page">
    <div class="rooms-header">
        <h1>Our Rooms</h1>
        <p>Find the perfect room for your stay</p>
    </div>

    <div class="filter-tabs">
        <button class="filter-btn active" data-filter="all">All Rooms</button>
        @foreach (var t in types)
        {
            <button class="filter-btn" data-filter="@t">@t</button>
        }
    </div>

    <div class="rooms-grid" id="roomsGrid">
        @foreach (var room in Model.Rooms)
        {
            bool unavailable = room.DisplayStatus != "Available";

            <div class="room-card" data-type="@room.Type" style="display:flex">
                <div class="room-img-wrap">
                    <span class="room-badge">@room.Type</span>
                    <img src="/@room.ImagePath" alt="Room @room.RoomNumber" />
                    @if (unavailable)
                    {
                        <div class="room-overlay">
                            <span class="overlay-status">@room.DisplayStatus.ToUpper()</span>
                            @if (room.AvailableFrom.HasValue)
                            {
                                <span class="overlay-available">
                                    <i class="fa-regular fa-calendar"></i>
                                    Available @room.AvailableFrom.Value.ToString("MMM d, yyyy")
                                </span>
                            }
                        </div>
                    }
                </div>
                <div class="room-body">
                    <div class="room-title-row">
                        <h3>Room @room.RoomNumber</h3>
                        <span class="room-price">
                            <span class="dollar">$</span>@room.PricePerNight.ToString("0.##")<span class="per">/night</span>
                        </span>
                    </div>
                    <p class="room-desc">@room.Description</p>
                    <div class="room-amenities">
                        <span><i class="fa-solid fa-user-group"></i> @room.Capacity</span>
                        <span><i class="fa-solid fa-wifi"></i> Wi-Fi</span>
                        <span><i class="fa-solid fa-tv"></i> TV</span>
                        <span><i class="fa-solid fa-wind"></i> AC</span>
                    </div>
                    @if (unavailable)
                    {
                        <button class="btn-book unavailable" disabled>Unavailable</button>
                    }
                    else
                    {
                        <a href="/BookRoom/@room.RoomId" class="btn-book">Book Now</a>
                    }
                </div>
            </div>
        }
    </div>
</div>

<!-- FOOTER -->
<footer class="rooms-footer">
    <div class="footer-inner">
        <div class="footer-col">
            <h3><i class="fa-solid fa-building fa-sm" style="color:#b07a2a"></i> Grand Haven</h3>
            <p>Experience luxury and comfort in the heart of the city. Your perfect getaway awaits.</p>
        </div>
        <div class="footer-col">
            <h4>Contact</h4>
            <p><i class="fa-solid fa-phone" style="color:#b07a2a"></i> +250791375079</p>
            <p><i class="fa-solid fa-envelope" style="color:#b07a2a"></i> info@grandhaven.com</p>
            <p><i class="fa-solid fa-location-dot" style="color:#b07a2a"></i> Kigali, Rwanda</p>
        </div>
        <div class="footer-col">
            <h4>Quick Links</h4>
            <p><a href="#">About Us</a></p>
            <p><a href="/Rooms">Our Rooms</a></p>
            <p><a href="/Events">Events</a></p>
            <p><a href="/Contact">Contact</a></p>
        </div>
    </div>
    <div class="footer-bottom">
        <p>© 2026 Grand Haven Hotel. All rights reserved.</p>
    </div>
</footer>

@section Scripts {
<script>
    const btns  = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.room-card');

    btns.forEach(btn => {
        btn.addEventListener('click', () => {
            btns.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            const filter = btn.dataset.filter;
            cards.forEach(card => {
                card.style.display = (filter === 'all' || card.dataset.type === filter) ? 'flex' : 'none';
            });
        });
    });
</script>
}
