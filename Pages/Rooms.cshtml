@page
@model HotelBookingSystem.Pages.RoomsModel
@{
    ViewData["Title"] = "Rooms";
    var types = Model.Rooms.Select(r => r.Type).Distinct().OrderBy(t => t).ToList();
    int availableCount = Model.Rooms.Count(r => r.DisplayStatus == "Available");
}
<link rel="stylesheet" href="~/css/Rooms.css" />

<!-- HERO BANNER -->
<div class="rooms-hero">
    <div class="rooms-hero-overlay">
        <span class="rooms-tag"><i class="fa-solid fa-bed"></i> Accommodations</span>
        <h1>Find Your Perfect Room</h1>
        <p>@availableCount room@(availableCount != 1 ? "s" : "") available right now &mdash; from cozy singles to lavish suites</p>
    </div>
</div>

<div class="rooms-page">
    <!-- FILTER BAR -->
    <div class="filter-bar">
        <div class="filter-tabs">
            <button class="filter-btn active" data-filter="all">
                <i class="fa-solid fa-border-all"></i> All
                <span class="filter-count">@Model.Rooms.Count</span>
            </button>
            @foreach (var t in types)
            {
                int count = Model.Rooms.Count(r => r.Type == t);
                <button class="filter-btn" data-filter="@t">
                    @t <span class="filter-count">@count</span>
                </button>
            }
        </div>
    </div>

    <!-- ROOMS GRID -->
    <div class="rooms-grid" id="roomsGrid">
        @foreach (var room in Model.Rooms)
        {
            bool unavailable = room.DisplayStatus != "Available";
            <div class="room-card @(unavailable ? "room-card-unavailable" : "")" data-type="@room.Type" style="display:flex">
                <div class="room-img-wrap">
                    <span class="room-type-badge">@room.Type</span>
                    <img src="/@room.ImagePath" alt="Room @room.RoomNumber" />
                    @if (unavailable)
                    {
                        <div class="room-overlay">
                            <i class="fa-regular fa-calendar-xmark"></i>
                            <span class="overlay-status">@room.DisplayStatus.ToUpper()</span>
                            @if (room.AvailableFrom.HasValue)
                            {
                                <span class="overlay-available">
                                    <i class="fa-regular fa-calendar-check"></i>
                                    Free from @room.AvailableFrom.Value.ToString("MMM d, yyyy")
                                </span>
                            }
                        </div>
                    }
                </div>
                <div class="room-body">
                    <div class="room-title-row">
                        <h3>Room @room.RoomNumber</h3>
                        <div class="room-price">
                            <span class="price-amount">$@room.PricePerNight.ToString("0.##")</span>
                            <span class="price-per">/night</span>
                        </div>
                    </div>
                    <p class="room-desc">@room.Description</p>
                    <div class="room-amenities">
                        <span class="amenity-pill"><i class="fa-solid fa-user-group"></i> @room.Capacity Guest@(room.Capacity > 1 ? "s" : "")</span>
                        <span class="amenity-pill"><i class="fa-solid fa-wifi"></i> Wi-Fi</span>
                        <span class="amenity-pill"><i class="fa-solid fa-tv"></i> TV</span>
                        <span class="amenity-pill"><i class="fa-solid fa-wind"></i> AC</span>
                    </div>
                    @if (unavailable)
                    {
                        <button class="btn-book btn-book-unavailable" disabled>
                            <i class="fa-solid fa-ban"></i> Unavailable
                        </button>
                    }
                    else
                    {
                        <a href="/BookRoom/@room.RoomId" class="btn-book">
                            <i class="fa-solid fa-calendar-plus"></i> Book Now
                        </a>
                    }
                </div>
            </div>
        }
    </div>
</div>

<!-- FOOTER -->
<footer class="rooms-footer">
    <div class="footer-inner">
        <div class="footer-col">
            <h3><i class="fa-solid fa-hotel"></i> Grand Haven</h3>
            <p>Experience luxury and comfort in the heart of the city. Your perfect getaway awaits.</p>
        </div>
        <div class="footer-col">
            <h4>Contact</h4>
            <p><i class="fa-solid fa-phone"></i> +250 791 375 079</p>
            <p><i class="fa-solid fa-envelope"></i> info@grandhaven.com</p>
            <p><i class="fa-solid fa-location-dot"></i> Kigali, Rwanda</p>
        </div>
        <div class="footer-col">
            <h4>Quick Links</h4>
            <a href="/Rooms">Our Rooms</a>
            <a href="/Events">Events</a>
            <a href="/Contact">Contact</a>
            <a href="/Login">Login</a>
        </div>
    </div>
    <div class="footer-bottom">
        <p>&copy; 2026 Grand Haven Hotel. All rights reserved.</p>
    </div>
</footer>

@section Scripts {
<script>
    const btns  = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.room-card');

    btns.forEach(btn => {
        btn.addEventListener('click', () => {
            btns.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            const filter = btn.dataset.filter;
            cards.forEach(card => {
                card.style.display = (filter === 'all' || card.dataset.type === filter) ? 'flex' : 'none';
            });
        });
    });
</script>
}
