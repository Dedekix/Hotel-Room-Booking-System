@page
@model HotelBookingSystem.Pages.RoomsModel
@{
    ViewData["Title"] = "Rooms";
}
<link rel="stylesheet" href="~/css/Rooms.css" />

<div class="rooms-page">
    <div class="rooms-header">
        <h1>Our Rooms</h1>
        <p>Find the perfect room for your stay</p>
    </div>

    <div class="filter-tabs">
        <button class="filter-btn active" data-filter="all">All Rooms</button>
        <button class="filter-btn" data-filter="Standard">Standard</button>
        <button class="filter-btn" data-filter="Deluxe">Deluxe</button>
        <button class="filter-btn" data-filter="Suite">Suite</button>
    </div>

    <div class="rooms-grid" id="roomsGrid">

        <!-- Room 101 - Standard - Available -->
        <div class="room-card" data-type="Standard">
            <div class="room-img-wrap">
                <span class="room-badge">Standard</span>
                <img src="/Images/room101.jpg" alt="Room 101" />
            </div>
            <div class="room-body">
                <div class="room-title-row">
                    <h3>Room 101</h3>
                    <span class="room-price"><span class="dollar">$</span>120<span class="per">/night</span></span>
                </div>
                <p class="room-desc">Comfortable room with modern amenities, perfect for business or leisure travelers.</p>
                <div class="room-amenities">
                    <span><i class="fa-solid fa-user-group"></i> 2</span>
                    <span><i class="fa-solid fa-wifi"></i> Wi-Fi</span>
                    <span><i class="fa-solid fa-tv"></i> TV</span>
                    <span><i class="fa-solid fa-wind"></i> AC</span>
                </div>
                <button class="btn-book">Book Now</button>
            </div>
        </div>

        <!-- Room 102 - Standard - Available -->
        <div class="room-card" data-type="Standard">
            <div class="room-img-wrap">
                <span class="room-badge">Standard</span>
                <img src="/Images/room101.jpg" alt="Room 102" />
            </div>
            <div class="room-body">
                <div class="room-title-row">
                    <h3>Room 102</h3>
                    <span class="room-price"><span class="dollar">$</span>120<span class="per">/night</span></span>
                </div>
                <p class="room-desc">Comfortable room with modern amenities, perfect for business or leisure travelers.</p>
                <div class="room-amenities">
                    <span><i class="fa-solid fa-user-group"></i> 2</span>
                    <span><i class="fa-solid fa-wifi"></i> Wi-Fi</span>
                    <span><i class="fa-solid fa-tv"></i> TV</span>
                    <span><i class="fa-solid fa-wind"></i> AC</span>
                </div>
                <button class="btn-book">Book Now</button>
            </div>
        </div>

        <!-- Room 201 - Deluxe - Available -->
        <div class="room-card" data-type="Deluxe">
            <div class="room-img-wrap">
                <span class="room-badge">Deluxe</span>
                <img src="/Images/room201.jpg" alt="Room 201" />
            </div>
            <div class="room-body">
                <div class="room-title-row">
                    <h3>Room 201</h3>
                    <span class="room-price"><span class="dollar">$</span>220<span class="per">/night</span></span>
                </div>
                <p class="room-desc">Spacious deluxe room with stunning city views and premium furnishings.</p>
                <div class="room-amenities">
                    <span><i class="fa-solid fa-user-group"></i> 3</span>
                    <span><i class="fa-solid fa-wifi"></i> Wi-Fi</span>
                    <span><i class="fa-solid fa-tv"></i> TV</span>
                    <span><i class="fa-solid fa-wind"></i> AC</span>
                </div>
                <button class="btn-book">Book Now</button>
            </div>
        </div>

        <!-- Room 202 - Deluxe - Occupied -->
        <div class="room-card" data-type="Deluxe">
            <div class="room-img-wrap">
                <span class="room-badge">Deluxe</span>
                <img src="/Images/room201.jpg" alt="Room 202" />
                <div class="room-overlay">
                    <span class="overlay-status">OCCUPIED</span>
                    <span class="overlay-available"><i class="fa-regular fa-clock"></i> Available Apr 5, 2026</span>
                </div>
            </div>
            <div class="room-body">
                <div class="room-title-row">
                    <h3>Room 202</h3>
                    <span class="room-price"><span class="dollar">$</span>220<span class="per">/night</span></span>
                </div>
                <p class="room-desc">Spacious deluxe room with stunning city views and premium furnishings.</p>
                <div class="room-amenities">
                    <span><i class="fa-solid fa-user-group"></i> 3</span>
                    <span><i class="fa-solid fa-wifi"></i> Wi-Fi</span>
                    <span><i class="fa-solid fa-tv"></i> TV</span>
                    <span><i class="fa-solid fa-wind"></i> AC</span>
                </div>
                <button class="btn-book unavailable" disabled>Unavailable</button>
            </div>
        </div>

        <!-- Room 301 - Suite - Available -->
        <div class="room-card" data-type="Suite">
            <div class="room-img-wrap">
                <span class="room-badge">Suite</span>
                <img src="/Images/room301.jpg" alt="Room 301" />
            </div>
            <div class="room-body">
                <div class="room-title-row">
                    <h3>Room 301</h3>
                    <span class="room-price"><span class="dollar">$</span>450<span class="per">/night</span></span>
                </div>
                <p class="room-desc">Luxurious suite with separate living area, jacuzzi, and panoramic views.</p>
                <div class="room-amenities">
                    <span><i class="fa-solid fa-user-group"></i> 4</span>
                    <span><i class="fa-solid fa-wifi"></i> Wi-Fi</span>
                    <span><i class="fa-solid fa-tv"></i> TV</span>
                    <span><i class="fa-solid fa-wind"></i> AC</span>
                </div>
                <button class="btn-book">Book Now</button>
            </div>
        </div>

        <!-- Room 302 - Suite - Maintenance -->
        <div class="room-card" data-type="Suite">
            <div class="room-img-wrap">
                <span class="room-badge">Suite</span>
                <img src="/Images/room301.jpg" alt="Room 302" />
                <div class="room-overlay">
                    <span class="overlay-status">MAINTENANCE</span>
                    <span class="overlay-available"><i class="fa-regular fa-clock"></i> Available Apr 10, 2026</span>
                </div>
            </div>
            <div class="room-body">
                <div class="room-title-row">
                    <h3>Room 302</h3>
                    <span class="room-price"><span class="dollar">$</span>450<span class="per">/night</span></span>
                </div>
                <p class="room-desc">Luxurious suite with separate living area, jacuzzi, and panoramic views.</p>
                <div class="room-amenities">
                    <span><i class="fa-solid fa-user-group"></i> 4</span>
                    <span><i class="fa-solid fa-wifi"></i> Wi-Fi</span>
                    <span><i class="fa-solid fa-tv"></i> TV</span>
                    <span><i class="fa-solid fa-wind"></i> AC</span>
                </div>
                <button class="btn-book unavailable" disabled>Unavailable</button>
            </div>
        </div>

    </div>
</div>

<!-- FOOTER -->
<footer class="rooms-footer">
    <div class="footer-inner">
        <div class="footer-col">
            <h3><i class="fa-solid fa-building fa-sm" style="color:#b07a2a"></i> Grand Haven</h3>
            <p>Experience luxury and comfort in the heart of the city. Your perfect getaway awaits.</p>
        </div>
        <div class="footer-col">
            <h4>Contact</h4>
            <p><i class="fa-solid fa-phone" style="color:#b07a2a"></i> +1 (555) 123-4567</p>
            <p><i class="fa-solid fa-envelope" style="color:#b07a2a"></i> info@grandhaven.com</p>
            <p><i class="fa-solid fa-location-dot" style="color:#b07a2a"></i> 123 Luxury Ave, New York</p>
        </div>
        <div class="footer-col">
            <h4>Quick Links</h4>
            <p><a href="#">About Us</a></p>
            <p><a href="/Rooms">Our Rooms</a></p>
            <p><a href="#">Privacy Policy</a></p>
        </div>
    </div>
    <div class="footer-bottom">
        <p>© 2026 Grand Haven Hotel. All rights reserved.</p>
    </div>
</footer>

@section Scripts {
<script>
    const btns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.room-card');

    btns.forEach(btn => {
        btn.addEventListener('click', () => {
            btns.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            const filter = btn.dataset.filter;
            cards.forEach(card => {
                card.style.display = (filter === 'all' || card.dataset.type === filter) ? 'flex' : 'none';
            });
        });
    });
</script>
}
