@page "{roomId:int}"
@model HotelBookingSystem.Pages.BookRoomModel
@{
    ViewData["Title"] = "Book Room";
}
<link rel="stylesheet" href="~/css/BookRoom.css" />

<div class="bookroom-page">

    <a href="/Rooms" class="back-link"><i class="fa-solid fa-arrow-left"></i> Back</a>

    <div class="bookroom-layout">

        <!-- LEFT: Room Info -->
        <div class="bookroom-left">
            <img src="/@Model.ImagePath" alt="Room @Model.RoomNumber" class="bookroom-img" />
            <h2 class="bookroom-room-title">Room @Model.RoomNumber &mdash; @Model.RoomType</h2>
            <p class="bookroom-room-desc">@Model.Description</p>
            <div class="bookroom-tags">
                <span class="amenity-tag">Wi-Fi</span>
                <span class="amenity-tag">TV</span>
                <span class="amenity-tag">Air Conditioning</span>
                <span class="amenity-tag">Mini Bar</span>
            </div>
            <div class="bookroom-pricing">
                <span class="price-night">
                    <span class="dollar">$</span>@Model.PricePerNight.ToString("0.##")<span class="per">/night</span>
                </span>
                <span class="price-hour">or $@((Model.PricePerNight / 8).ToString("0.##"))/hour</span>
            </div>
        </div>

        <!-- RIGHT: Booking Form -->
        <div class="bookroom-right">
            <h2>Book This Room</h2>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="booking-error">@Model.ErrorMessage</div>
            }

            <form method="post">
                <input type="hidden" name="roomId" value="@Model.RoomId" />
                <input type="hidden" name="bookingType" id="bookingTypeInput" value="DAILY" />

                <div class="form-group">
                    <label>Booking Type</label>
                    <div class="booking-type-toggle">
                        <button type="button" class="type-btn active" id="btnDaily" onclick="setType('DAILY')">
                            <i class="fa-regular fa-calendar"></i> Daily
                        </button>
                        <button type="button" class="type-btn" id="btnHourly" onclick="setType('HOURLY')">
                            <i class="fa-regular fa-clock"></i> Hourly
                        </button>
                    </div>
                </div>

                <div class="form-group">
                    <label>Full Name</label>
                    <input type="text" name="fullName" placeholder="John Smith" required />
                </div>

                <div class="form-group">
                    <label>Email</label>
                    <input type="email" name="email" placeholder="john@email.com" required />
                </div>

                <!-- DAILY FIELDS -->
                <div id="dailyFields">
                    <div class="form-row">
                        <div class="form-group half">
                            <label>Check-in Date</label>
                            <div class="input-icon">
                                <i class="fa-regular fa-calendar"></i>
                                <input type="date" name="checkInDate" id="checkInDate" />
                            </div>
                        </div>
                        <div class="form-group half">
                            <label>Check-out Date</label>
                            <div class="input-icon">
                                <i class="fa-regular fa-calendar"></i>
                                <input type="date" name="checkOutDate" id="checkOutDate" />
                            </div>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group half">
                            <label>Check-in Time</label>
                            <div class="select-wrap">
                                <select name="checkInTime">
                                    @for (int h = 0; h < 24; h++)
                                    {
                                        var val = h.ToString("D2") + ":00";
                                        if (h == 14) { <option value="@val" selected>@val</option> }
                                        else { <option value="@val">@val</option> }
                                    }
                                </select>
                                <i class="fa-solid fa-chevron-down"></i>
                            </div>
                        </div>
                        <div class="form-group half">
                            <label>Check-out Time</label>
                            <div class="select-wrap">
                                <select name="checkOutTime">
                                    @for (int h = 0; h < 24; h++)
                                    {
                                        var val = h.ToString("D2") + ":00";
                                        if (h == 12) { <option value="@val" selected>@val</option> }
                                        else { <option value="@val">@val</option> }
                                    }
                                </select>
                                <i class="fa-solid fa-chevron-down"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- HOURLY FIELDS -->
                <div id="hourlyFields" style="display:none">
                    <div class="form-group">
                        <label>Date</label>
                        <div class="input-icon">
                            <i class="fa-regular fa-calendar"></i>
                            <input type="date" name="hourlyDate" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group half">
                            <label>Start Time</label>
                            <div class="select-wrap">
                                <select name="startTime">
                                    @for (int h = 0; h < 24; h++)
                                    {
                                        var val = h.ToString("D2") + ":00";
                                        if (h == 14) { <option value="@val" selected>@val</option> }
                                        else { <option value="@val">@val</option> }
                                    }
                                </select>
                                <i class="fa-solid fa-chevron-down"></i>
                            </div>
                        </div>
                        <div class="form-group half">
                            <label>Duration (hours)</label>
                            <input type="number" name="durationHours" value="2" min="1" max="12" />
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label>Guests</label>
                    <div class="guests-row">
                        <i class="fa-regular fa-user"></i>
                        <input type="number" name="guestCount" value="1" min="1" max="@Model.Capacity" />
                        <span class="max-guests">Max @Model.Capacity</span>
                    </div>
                </div>

                <button type="submit" class="btn-confirm">Confirm Booking</button>
            </form>
        </div>

    </div>
</div>

@section Scripts {
<script>
    function setType(type) {
        const isDaily = type === 'DAILY';
        document.getElementById('bookingTypeInput').value = type;
        document.getElementById('btnDaily').classList.toggle('active', isDaily);
        document.getElementById('btnHourly').classList.toggle('active', !isDaily);
        document.getElementById('dailyFields').style.display  = isDaily ? 'block' : 'none';
        document.getElementById('hourlyFields').style.display = isDaily ? 'none'  : 'block';
    }
</script>
}
