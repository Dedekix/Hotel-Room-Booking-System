@page "{roomId:int}"
@model HotelBookingSystem.Pages.BookRoomModel
@{
    ViewData["Title"] = "Book Room";
}
<link rel="stylesheet" href="~/css/BookRoom.css" />

<div class="bookroom-page">

    <a href="/Rooms" class="back-link"><i class="fa-solid fa-arrow-left"></i> Back to Rooms</a>

    <div class="bookroom-layout">

        <!-- LEFT: Room Summary -->
        <div class="bookroom-left">
            <div class="room-summary-card">
                <div class="room-img-wrap">
                    <img src="/@Model.ImagePath" alt="Room @Model.RoomNumber" class="bookroom-img" />
                    <span class="room-type-label">@Model.RoomType</span>
                </div>
                <div class="room-summary-body">
                    <h2 class="bookroom-room-title">Room @Model.RoomNumber</h2>
                    <p class="bookroom-room-desc">@Model.Description</p>

                    <div class="bookroom-tags">
                        <span class="amenity-tag"><i class="fa-solid fa-wifi"></i> Wi-Fi</span>
                        <span class="amenity-tag"><i class="fa-solid fa-tv"></i> TV</span>
                        <span class="amenity-tag"><i class="fa-solid fa-wind"></i> AC</span>
                        <span class="amenity-tag"><i class="fa-solid fa-martini-glass-citrus"></i> Mini Bar</span>
                        <span class="amenity-tag"><i class="fa-solid fa-user-group"></i> Max @Model.Capacity Guests</span>
                    </div>

                    <div class="bookroom-pricing">
                        <div class="pricing-row">
                            <span><i class="fa-regular fa-moon"></i> Per Night</span>
                            <strong>$@Model.PricePerNight.ToString("0.##")</strong>
                        </div>
                        <div class="pricing-row">
                            <span><i class="fa-regular fa-clock"></i> Per Hour</span>
                            <strong>$@((Model.PricePerNight / 8).ToString("0.##"))</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT: Booking Form -->
        <div class="bookroom-right">
            <div class="form-card">
                <div class="form-card-header">
                    <h2><i class="fa-solid fa-calendar-plus"></i> Book This Room</h2>
                    <p>Fill in your details to complete the reservation</p>
                </div>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="booking-error"><i class="fa-solid fa-circle-exclamation"></i> @Model.ErrorMessage</div>
                }

                <form method="post">
                    <input type="hidden" name="roomId" value="@Model.RoomId" />
                    <input type="hidden" name="bookingType" id="bookingTypeInput" value="DAILY" />

                    <!-- Booking Type -->
                    <div class="form-section">
                        <div class="form-section-label">Booking Type</div>
                        <div class="booking-type-toggle">
                            <button type="button" class="type-btn active" id="btnDaily" onclick="setType('DAILY')">
                                <i class="fa-regular fa-calendar"></i> Daily
                            </button>
                            <button type="button" class="type-btn" id="btnHourly" onclick="setType('HOURLY')">
                                <i class="fa-regular fa-clock"></i> Hourly
                            </button>
                        </div>
                    </div>

                    <!-- Guest -->
                    <div class="form-section">
                        <div class="form-section-label">Booking As</div>
                        <div class="form-group">
                            <div class="input-icon">
                                <i class="fa-solid fa-circle-user"></i>
                                <input type="text" value="@Model.LoggedInName" disabled />
                            </div>
                        </div>
                    </div>

                    <!-- DAILY FIELDS -->
                    <div id="dailyFields">
                        <div class="form-section">
                            <div class="form-section-label">Stay Dates</div>
                            <div class="form-row">
                                <div class="form-group half">
                                    <label>Check-in Date</label>
                                    <div class="input-icon">
                                        <i class="fa-regular fa-calendar"></i>
                                        <input type="date" name="checkInDate" id="checkInDate" />
                                    </div>
                                </div>
                                <div class="form-group half">
                                    <label>Check-out Date</label>
                                    <div class="input-icon">
                                        <i class="fa-regular fa-calendar"></i>
                                        <input type="date" name="checkOutDate" id="checkOutDate" />
                                    </div>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group half">
                                    <label>Check-in Time</label>
                                    <div class="select-wrap">
                                        <select name="checkInTime">
                                            @for (int h = 0; h < 24; h++)
                                            {
                                                var val = h.ToString("D2") + ":00";
                                                if (h == 14) { <option value="@val" selected>@val</option> }
                                                else { <option value="@val">@val</option> }
                                            }
                                        </select>
                                        <i class="fa-solid fa-chevron-down"></i>
                                    </div>
                                </div>
                                <div class="form-group half">
                                    <label>Check-out Time</label>
                                    <div class="select-wrap">
                                        <select name="checkOutTime">
                                            @for (int h = 0; h < 24; h++)
                                            {
                                                var val = h.ToString("D2") + ":00";
                                                if (h == 12) { <option value="@val" selected>@val</option> }
                                                else { <option value="@val">@val</option> }
                                            }
                                        </select>
                                        <i class="fa-solid fa-chevron-down"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- HOURLY FIELDS -->
                    <div id="hourlyFields" style="display:none">
                        <div class="form-section">
                            <div class="form-section-label">Hourly Details</div>
                            <div class="form-group">
                                <label>Date</label>
                                <div class="input-icon">
                                    <i class="fa-regular fa-calendar"></i>
                                    <input type="date" name="hourlyDate" />
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group half">
                                    <label>Start Time</label>
                                    <div class="select-wrap">
                                        <select name="startTime">
                                            @for (int h = 0; h < 24; h++)
                                            {
                                                var val = h.ToString("D2") + ":00";
                                                if (h == 14) { <option value="@val" selected>@val</option> }
                                                else { <option value="@val">@val</option> }
                                            }
                                        </select>
                                        <i class="fa-solid fa-chevron-down"></i>
                                    </div>
                                </div>
                                <div class="form-group half">
                                    <label>Duration (hours)</label>
                                    <input type="number" name="durationHours" value="2" min="1" max="12" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Guests -->
                    <div class="form-section">
                        <div class="form-section-label">Guests</div>
                        <div class="form-group">
                            <div class="guests-row">
                                <button type="button" class="guest-btn" onclick="changeGuests(-1)"><i class="fa-solid fa-minus"></i></button>
                                <input type="number" name="guestCount" id="guestCount" value="1" min="1" max="@Model.Capacity" readonly />
                                <button type="button" class="guest-btn" onclick="changeGuests(1)"><i class="fa-solid fa-plus"></i></button>
                                <span class="max-guests">Max @Model.Capacity</span>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn-confirm">
                        <i class="fa-solid fa-check"></i> Confirm Booking
                    </button>
                </form>
            </div>
        </div>

    </div>
</div>

<!-- FOOTER -->
<footer class="bookroom-footer">
    <div class="footer-inner">
        <div class="footer-col">
            <h3><i class="fa-solid fa-hotel"></i> Grand Haven</h3>
            <p>Experience luxury and comfort in the heart of the city. Your perfect getaway awaits.</p>
        </div>
        <div class="footer-col">
            <h4>Contact</h4>
            <p><i class="fa-solid fa-phone"></i> +250 791 375 079</p>
            <p><i class="fa-solid fa-envelope"></i> info@grandhaven.com</p>
            <p><i class="fa-solid fa-location-dot"></i> Kigali, Rwanda</p>
        </div>
        <div class="footer-col">
            <h4>Quick Links</h4>
            <a href="/Index">Home</a>
            <a href="/Rooms">Rooms</a>
            <a href="/Events">Events</a>
            <a href="/Contact">Contact</a>
        </div>
    </div>
    <div class="footer-bottom">
        <p>&copy; 2026 Grand Haven Hotel. All rights reserved.</p>
    </div>
</footer>

@section Scripts {
<script>
    function setType(type) {
        const isDaily = type === 'DAILY';
        document.getElementById('bookingTypeInput').value = type;
        document.getElementById('btnDaily').classList.toggle('active', isDaily);
        document.getElementById('btnHourly').classList.toggle('active', !isDaily);
        document.getElementById('dailyFields').style.display  = isDaily ? 'block' : 'none';
        document.getElementById('hourlyFields').style.display = isDaily ? 'none'  : 'block';
    }

    function changeGuests(delta) {
        const input = document.getElementById('guestCount');
        const max   = parseInt(input.max);
        const val   = parseInt(input.value) + delta;
        if (val >= 1 && val <= max) input.value = val;
    }
</script>
}
