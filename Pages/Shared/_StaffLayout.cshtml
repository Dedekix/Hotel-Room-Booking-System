<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Personnel Portal</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/Staff.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Chat.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <script src="~/js/site.js" asp-append-version="true" defer></script>
</head>
<body class="staff-body">
@{
    var userRole = Context.Session.GetString("UserRole");
    if (userRole != "STAFF" && userRole != "ADMIN")
    {
        Context.Response.Redirect("/Login?returnUrl=/Staff/Dashboard");
        return;
    }
    bool isAdmin = userRole == "ADMIN";
    var userName = Context.Session.GetString("UserFullName") ?? "User";
    var userInitials = string.Join("", userName.Split(' ').Take(2).Select(w => w[0].ToString().ToUpper()));
}

    <div class="staff-wrapper">
        <!-- Sidebar -->
        <aside class="staff-sidebar">
            <!-- Logo -->
            <div class="sidebar-logo">
                <svg viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M26 3 L46 12 L46 30 Q46 42 26 50 Q6 42 6 30 L6 12 Z" fill="#1a1208"/>
                    <path d="M26 8 L42 16 L42 30 Q42 40 26 47 Q10 40 10 30 L10 16 Z" fill="none" stroke="#f0a94b" stroke-width="1"/>
                    <path d="M18 20 L20 15 L26 19 L32 15 L34 20 Z" fill="#f0a94b"/>
                    <rect x="17" y="20" width="18" height="2" rx="1" fill="#f0a94b"/>
                    <rect x="19" y="22" width="14" height="12" rx="1" fill="white" opacity="0.1"/>
                    <rect x="23" y="28" width="6" height="6" rx="0.8" fill="#f0a94b"/>
                    <rect x="20" y="24" width="4" height="3" rx="0.5" fill="#f0a94b" opacity="0.7"/>
                    <rect x="28" y="24" width="4" height="3" rx="0.5" fill="#f0a94b" opacity="0.7"/>
                </svg>
                <div class="sidebar-logo-text">
                    <span class="sidebar-logo-name">Grand Haven</span>
                    <span class="sidebar-logo-role">@(isAdmin ? "Admin Panel" : "Staff Portal")</span>
                </div>
            </div>

            <!-- Nav -->
            <div class="sidebar-section-label">Main Menu</div>
            <nav class="sidebar-nav">
                <a href="/Staff/Dashboard" class="nav-item @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="fa-solid fa-gauge"></i> <span>Dashboard</span>
                </a>
                <a href="/Staff/Bookings" class="nav-item @(ViewData["ActivePage"]?.ToString() == "Bookings" ? "active" : "")">
                    <i class="fa-regular fa-calendar-check"></i> <span>Room Bookings</span>
                </a>
                <a href="/Staff/EventBookings" class="nav-item @(ViewData["ActivePage"]?.ToString() == "EventBookings" ? "active" : "")">
                    <i class="fa-solid fa-ticket"></i> <span>Event Reservations</span>
                </a>
                <a href="/Staff/Chat" class="nav-item @(ViewData["ActivePage"]?.ToString() == "Chat" ? "active" : "")" id="chatNavItem">
                    <i class="fa-solid fa-headset"></i> <span>Chat Support</span>
                    <span class="nav-unread-badge" id="chatUnreadBadge" style="display:none"></span>
                </a>
                @if (isAdmin)
                {
                    <div class="sidebar-section-label">Management</div>
                    <a href="/Staff/Rooms" class="nav-item @(ViewData["ActivePage"]?.ToString() == "Rooms" ? "active" : "")">
                        <i class="fa-solid fa-bed"></i> <span>Rooms</span>
                    </a>
                    <a href="/Staff/Events" class="nav-item @(ViewData["ActivePage"]?.ToString() == "Events" ? "active" : "")">
                        <i class="fa-solid fa-calendar-star"></i> <span>Events</span>
                    </a>
                    <a href="/Staff/Reports" class="nav-item @(ViewData["ActivePage"]?.ToString() == "Reports" ? "active" : "")">
                        <i class="fa-solid fa-chart-bar"></i> <span>Reports</span>
                    </a>
                    <a href="/Staff/Messages" class="nav-item @(ViewData["ActivePage"]?.ToString() == "Messages" ? "active" : "")">
                        <i class="fa-solid fa-envelope"></i> <span>Messages</span>
                    </a>
                    <a href="/Staff/ManageStaff" class="nav-item @(ViewData["ActivePage"]?.ToString() == "ManageStaff" ? "active" : "")">
                        <i class="fa-solid fa-users-gear"></i> <span>Staff</span>
                    </a>
                }
            </nav>

            <!-- User Card -->
            <div class="sidebar-user">
                <div class="sidebar-user-avatar">@userInitials</div>
                <div class="sidebar-user-info">
                    <span class="sidebar-user-name">@userName</span>
                    <span class="sidebar-user-role">@(isAdmin ? "Administrator" : "Staff")</span>
                </div>
            </div>

            <!-- Footer Links -->
            <div class="sidebar-footer">
                <a href="/Index" class="sidebar-exit">
                    <i class="fa-solid fa-arrow-up-right-from-square"></i> View Site
                </a>
                <a href="/Logout" class="sidebar-exit sidebar-logout"
                   onclick="ghConfirm(event, 'Are you sure you want to log out?', () => window.location.href='/Logout')">
                    <i class="fa-solid fa-right-from-bracket"></i> Logout
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="staff-main">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // SIDEBAR CHAT NOTIFICATIONS:
        // Polls the Staff/Chat page every 10 seconds to get the total number 
        // of unread customer messages. This runs on every staff page.
        (async function pollChatUnread() {
            try {
                // Fetch current unread count from the server
                const res  = await fetch('/Staff/Chat?handler=UnreadCount');
                const data = await res.json();
                const badge = document.getElementById('chatUnreadBadge');
                
                if (badge) {
                    // If there are unread messages, show the red badge
                    if (data.count > 0) {
                        badge.textContent = data.count;
                        badge.style.display = 'inline-block';
                    } else {
                        // Hide the badge if all messages are read
                        badge.style.display = 'none';
                    }
                }
            } catch(e) {
                console.error('Staff sidebar poller error:', e);
            }
            // Schedule the next check in 10 seconds
            setTimeout(pollChatUnread, 10000);
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
