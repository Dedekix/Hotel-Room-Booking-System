<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Personnel Portal</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/Staff.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body class="staff-body">
@{
    var userRole = Context.Session.GetString("UserRole");
    if (userRole != "STAFF" && userRole != "ADMIN")
    {
        Context.Response.Redirect("/Login?returnUrl=/Staff/Dashboard");
        return;
    }
    bool isAdmin = userRole == "ADMIN";
}

    <div class="staff-wrapper">
        <!-- Sidebar -->
        <aside class="staff-sidebar">
            <div class="sidebar-logo">
                <i class="fa-solid fa-building" style="color:#b07a2a"></i>
                <span>Personnel Portal</span>
            </div>

            <nav class="sidebar-nav">
                <a href="/Staff/Dashboard" class="nav-item @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="fa-solid fa-gauge"></i> Dashboard
                </a>
                <a href="/Staff/Bookings" class="nav-item @(ViewData["ActivePage"]?.ToString() == "Bookings" ? "active" : "")">
                    <i class="fa-regular fa-calendar"></i> Bookings
                </a>
                @if (isAdmin)
                {
                <a href="/Staff/Rooms" class="nav-item @(ViewData["ActivePage"]?.ToString() == "Rooms" ? "active" : "")">
                    <i class="fa-solid fa-bed"></i> Rooms
                </a>
                <a href="/Staff/Events" class="nav-item @(ViewData["ActivePage"]?.ToString() == "Events" ? "active" : "")">
                    <span class="fa-stack" style="width:18px;height:18px;line-height:18px;font-size:9px;">
                        <i class="fa-solid fa-calendar fa-stack-2x"></i>
                        <i class="fa-solid fa-star fa-stack-1x" style="color:#b07a2a;margin-top:3px;"></i>
                    </span> Events
                </a>
                <a href="/Staff/Reports" class="nav-item @(ViewData["ActivePage"]?.ToString() == "Reports" ? "active" : "")">
                    <i class="fa-solid fa-chart-bar"></i> Reports
                </a>
                }
            </nav>

            <a href="/Index" class="sidebar-exit">
                <i class="fa-solid fa-arrow-right-from-bracket"></i> Exit
            </a>
        </aside>

        <!-- Main Content -->
        <main class="staff-main">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
