<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HotelBookingSystem</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home.css" />
    <link rel="stylesheet" href="~/css/login.css" />
    <link rel="stylesheet" href="~/HotelBookingSystem.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body>
    <header>
        <nav class="navbar">
            <div class="nav-left">
                <a href="/Index" class="logo">🏨 Grand Haven</a>
            </div>

            <div class="nav-center">
                <a href="/Index">Home</a>
                <a href="/Rooms" class="@(ViewData["Title"]?.ToString() == "Rooms" ? "nav-active" : "")">Rooms</a>
                <a href="/Events">Events</a>
                <a href="/Contact">Contact</a>
            </div>

            <div class="nav-right">
                <a href="/Login" class="login-link"><i class="fa-regular fa-user"></i> Login</a>
                <a href="/Staff/Dashboard" class="staff-portal-link">Staff Portal</a>
                @if (Context.Session.GetString("UserRole") == "ADMIN")
                {
                    <a href="/Admin/Dashboard" class="staff-portal-link" style="background:#b07a2a">Admin Panel</a>
                }
            </div>
        </nav>
    </header>
    <main role="main">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
