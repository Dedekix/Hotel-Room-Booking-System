<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Grand Haven Hotel</title>
    <link rel="stylesheet" href="~/css/site.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <nav class="navbar">
        <div class="container">
            <a href="/" class="logo">Grand Haven</a>
            <div class="nav-links">
                <a href="/">Home</a>
                <a href="/Rooms">Rooms</a>
                <a href="/MyBookings">My Bookings</a>
                <a href="/Signup">Sign Up</a>
                <a href="/Login">Login</a>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div>
                    <h4>Grand Haven</h4>
                    <p>Experience luxury and comfort in the heart of the city. Your perfect getaway awaits.</p>
                </div>
                <div>
                    <h4>Contact</h4>
                    <p>+1 (555) 123-4567</p>
                    <p>info@grandhaven.com</p>
                    <p>123 Luxury Ave, New York</p>
                </div>
                <div>
                    <h4>Quick Links</h4>
                    <p><a href="/About">About Us</a></p>
                    <p><a href="/Rooms">Our Rooms</a></p>
                    <p><a href="/Privacy">Privacy Policy</a></p>
                </div>
                <div>
                    <h4>Follow Us</h4>
                    <p><a href="#">Instagram</a></p>
                    <p><a href="#">Facebook</a></p>
                    <p><a href="#">Twitter</a></p>
                </div>
            </div>
            <div class="footer-bottom">
                <p>© 2026 Grand Haven Hotel. All rights reserved.</p>
            </div>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>