@page
@model HotelBookingSystem.Pages.Customer.VerifyOtpModel
@{
    ViewData["Title"] = "Verify OTP";
}
<link rel="stylesheet" href="~/css/login.css" />

<div class="auth-container">
    <div class="auth-panel">
        <div class="auth-panel-overlay">
            <div class="auth-panel-brand">
                <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M10 20 L14 10 L24 17 L34 10 L38 20 Z" fill="#f0a94b"/>
                    <rect x="9" y="20" width="30" height="3" rx="1.5" fill="#f0a94b"/>
                    <rect x="11" y="23" width="26" height="18" rx="2" fill="white"/>
                    <rect x="20" y="33" width="8" height="8" rx="1" fill="#f0a94b"/>
                    <rect x="14" y="27" width="5" height="4" rx="0.8" fill="#f0a94b" opacity="0.9"/>
                    <rect x="29" y="27" width="5" height="4" rx="0.8" fill="#f0a94b" opacity="0.9"/>
                    <rect x="8" y="41" width="32" height="2" rx="1" fill="#f0a94b"/>
                </svg>
                <h2>Grand Haven</h2>
                <p>Luxury Hotel</p>
            </div>
            <div class="auth-panel-quote">
                <blockquote>"Where every stay becomes a cherished memory."</blockquote>
            </div>
        </div>
    </div>

    <div class="auth-form-panel">
        <div class="auth-card">
            <div class="auth-card-header">
                <h2>Verify OTP</h2>
                <p class="subtitle">Enter the 6-digit code sent to your email</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="auth-error"><i class="fa-solid fa-circle-exclamation"></i> @Model.ErrorMessage</div>
            }

            <form method="post">
                <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                <div class="form-group">
                    <label for="otp"><i class="fa-solid fa-key"></i> OTP Code</label>
                    <input type="text" id="otp" name="otp" maxlength="6" placeholder="______"
                           autocomplete="one-time-code" required style="letter-spacing:0.4em; font-size:1.3rem; text-align:center;" />
                </div>
                <button type="submit" class="auth-submit"><i class="fa-solid fa-check"></i> Verify</button>
            </form>

            <p class="auth-switch" style="margin-top:1rem;">
                Didn't receive a code? <a href="/Login">Go back</a>
            </p>
        </div>
    </div>
</div>
