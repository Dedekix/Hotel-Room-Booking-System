@page
@model HotelBookingSystem.Pages.BookingConfirmedModel
@{
    ViewData["Title"] = "Booking Confirmed";
}
<link rel="stylesheet" href="~/css/BookRoom.css" />

<div class="bookroom-page" style="display:flex;align-items:center;justify-content:center;min-height:80vh">
    <div style="text-align:center;max-width:480px">
        <div style="font-size:60px;margin-bottom:16px">🎉</div>
        <h2 style="font-size:26px;font-weight:700;color:#1a1a1a;margin-bottom:10px">Booking Confirmed!</h2>
        <p style="color:#666;font-size:15px;margin-bottom:30px">
            Your room has been successfully booked. A confirmation will be sent to your email.
        </p>
        <a href="/MyBookings" style="background:#b07a2a;color:white;padding:13px 32px;border-radius:8px;text-decoration:none;font-weight:600;font-size:15px;margin-right:12px">
            View My Bookings
        </a>
        <a href="/Rooms" style="background:transparent;color:#b07a2a;padding:13px 32px;border-radius:8px;text-decoration:none;font-weight:600;font-size:15px;border:2px solid #b07a2a">
            Browse More Rooms
        </a>
    </div>
</div>
