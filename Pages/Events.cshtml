@page
@model HotelBookingSystem.Pages.EventsModel
@{
    ViewData["Title"] = "Events";
}
<link rel="stylesheet" href="~/css/Events.css" />

<div class="events-page">
    <div class="events-header">
        <h1>Events at Grand Haven</h1>
        <p>Be part of something extraordinary — reserve your spot today</p>
    </div>

    <div class="events-grid">
        @foreach (var ev in Model.Events)
        {
            <div class="event-card">
                <img src="/@ev.ImagePath" alt="@ev.Title" />
                <div class="event-body">
                    <span class="event-badge">@ev.Badge</span>
                    <h3>@ev.Title</h3>
                    <p class="event-date"><i class="fa-regular fa-calendar"></i> @ev.EventDate</p>
                    <p class="event-desc">@ev.Description</p>
                    <div class="event-meta">
                        <span><i class="fa-solid fa-location-dot"></i> @ev.Location</span>
                        <span><i class="fa-solid fa-users"></i> @ev.Capacity seats</span>
                        @if (ev.Price > 0)
                        {
                            <span><i class="fa-solid fa-tag"></i> $@ev.Price.ToString("0.##")</span>
                        }
                        else
                        {
                            <span><i class="fa-solid fa-tag"></i> Free</span>
                        }
                    </div>
                    <button class="btn-reserve" onclick="openModal(@ev.EventId, '@ev.Title', '@ev.EventDate')">Reserve a Spot</button>
                </div>
            </div>
        }
    </div>
</div>

<!-- RESERVATION MODAL -->
<div class="modal-backdrop" id="reserveModal">
    <div class="modal-box">
        <button class="modal-close" onclick="closeModal()">&times;</button>
        <h2>Reserve a Spot</h2>
        <p class="modal-event-name"><i class="fa-regular fa-calendar"></i> <span id="modalEventName"></span> &mdash; <span id="modalEventDate"></span></p>
        <form id="reserveForm">
            <input type="hidden" name="eventName" id="hiddenEventName" />
            <div class="form-group">
                <label>Full Name</label>
                <input type="text" name="fullName" placeholder="" required />
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" placeholder="" required />
            </div>
            <div class="form-group">
                <label>Phone</label>
                <input type="tel" name="phone" placeholder="" />
            </div>
            <button type="submit" class="btn-confirm-reserve">Confirm Reservation</button>
        </form>
        <div class="reserve-success" id="reserveSuccess" style="display:none">
            <i class="fa-solid fa-circle-check"></i> Your spot has been reserved!
        </div>
    </div>
</div>

<!-- FOOTER -->
<footer class="events-footer">
    <div class="footer-inner">
        <div class="footer-col">
            <h3><i class="fa-solid fa-building fa-sm" style="color:#b07a2a"></i> Grand Haven</h3>
            <p>Experience luxury and comfort in the heart of the city. Your perfect getaway awaits.</p>
        </div>
        <div class="footer-col">
            <h4>Contact</h4>
            <p><i class="fa-solid fa-phone" style="color:#b07a2a"></i> +250791375079</p>
            <p><i class="fa-solid fa-envelope" style="color:#b07a2a"></i> info@grandhaven.com</p>
            <p><i class="fa-solid fa-location-dot" style="color:#b07a2a"></i> Kigali, Rwanda</p>
        </div>
        <div class="footer-col">
            <h4>Quick Links</h4>
            <p><a href="/Index">Home</a></p>
            <p><a href="/Rooms">Our Rooms</a></p>
			<p><a href="/Events">Events</a></p>
            <p><a href="/Contact">Contact</a></p>
        </div>
    </div>
    <div class="footer-bottom">
        <p>&copy; 2026 Grand Haven Hotel. All rights reserved.</p>
    </div>
</footer>

@section Scripts {
<script>
    var isLoggedIn = @(HttpContext.Session.GetString("UserId") != null ? "true" : "false");

    function openModal(eventId, name, date) {
        if (!isLoggedIn) {
            window.location.href = '/Login';
            return;
        }
        document.getElementById('modalEventName').textContent = name;
        document.getElementById('modalEventDate').textContent = date;
        document.getElementById('hiddenEventId').value        = eventId;
        document.getElementById('reserveModal').classList.add('open');
    }
    function closeModal() {
        document.getElementById('reserveModal').classList.remove('open');
    }
    document.getElementById('reserveModal').addEventListener('click', function (e) {
        if (e.target === this) closeModal();
    });

    @if (Model.Reserved || !string.IsNullOrEmpty(Model.ErrorMessage)) {
        <text>
        window.addEventListener('DOMContentLoaded', () => {
            document.getElementById('reserveModal').classList.add('open');
        });
        </text>
    }
</script>
}
