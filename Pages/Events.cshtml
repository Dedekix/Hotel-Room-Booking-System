@page
@model HotelBookingSystem.Pages.EventsModel
@{
    ViewData["Title"] = "Events";
}
<link rel="stylesheet" href="~/css/Events.css" />

<div class="events-page">
    <div class="events-header">
        <div>
            <h1>Events at Grand Haven</h1>
            <p>Be part of something extraordinary — reserve your spot today</p>
        </div>
        <div class="events-search">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" id="eventSearch" placeholder="Search events..." oninput="filterEvents()" />
        </div>
    </div>

    <div class="events-grid" id="eventsGrid">
        @foreach (var ev in Model.Events)
        {
            <div class="event-card" data-title="@ev.Title.ToLower()">
                <img src="/@ev.ImagePath" alt="@ev.Title" />
                <div class="event-body">
                    <span class="event-badge">@ev.Badge</span>
                    <h3>@ev.Title</h3>
                    <p class="event-date"><i class="fa-regular fa-calendar"></i> @ev.EventDate</p>
                    <p class="event-desc">@ev.Description</p>
                    <div class="event-meta">
                        <span><i class="fa-solid fa-location-dot"></i> @ev.Location</span>
                        <span><i class="fa-solid fa-users"></i> @ev.Capacity seats</span>
                        @if (ev.Price > 0)
                        {
                            <span><i class="fa-solid fa-tag"></i> $@ev.Price.ToString("0.##")</span>
                        }
                        else
                        {
                            <span><i class="fa-solid fa-tag"></i> Free</span>
                        }
                    </div>
                    <a href="/BookEvent/@ev.EventId" class="btn-reserve">Reserve a Spot</a>
                </div>
            </div>
        }
    </div>
    <p class="events-no-results" id="noResults" style="display:none">No events match your search.</p>
</div>


<!-- FOOTER -->
<footer class="events-footer">
    <div class="footer-inner">
        <div class="footer-col">
            <h3><i class="fa-solid fa-building fa-sm" style="color:#b07a2a"></i> Grand Haven</h3>
            <p>Experience luxury and comfort in the heart of the city. Your perfect getaway awaits.</p>
        </div>
        <div class="footer-col">
            <h4>Contact</h4>
            <p><i class="fa-solid fa-phone" style="color:#b07a2a"></i> +250791375079</p>
            <p><i class="fa-solid fa-envelope" style="color:#b07a2a"></i> info@grandhaven.com</p>
            <p><i class="fa-solid fa-location-dot" style="color:#b07a2a"></i> Kigali, Rwanda</p>
        </div>
        <div class="footer-col">
            <h4>Quick Links</h4>
            <p><a href="/Index">Home</a></p>
            <p><a href="/Rooms">Our Rooms</a></p>
			<p><a href="/Events">Events</a></p>
            <p><a href="/Contact">Contact</a></p>
        </div>
    </div>
    <div class="footer-bottom">
        <p>&copy; 2026 Grand Haven Hotel. All rights reserved.</p>
    </div>
</footer>

@section Scripts {
<script>
    function filterEvents() {
        const q = document.getElementById('eventSearch').value.toLowerCase();
        const cards = document.querySelectorAll('#eventsGrid .event-card');
        let visible = 0;
        cards.forEach(card => {
            const match = card.dataset.title.includes(q);
            card.style.display = match ? '' : 'none';
            if (match) visible++;
        });
        document.getElementById('noResults').style.display = visible === 0 ? 'block' : 'none';
    }
</script>
}
