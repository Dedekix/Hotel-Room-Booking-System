@page
@model HotelBookingSystem.Pages.ContactModel
@{
    ViewData["Title"] = "Contact";
}
<link rel="stylesheet" href="~/css/Contact.css" />

<!-- HERO -->
<div class="contact-hero">
    <div class="contact-hero-overlay">
        <span class="contact-tag"><i class="fa-solid fa-headset"></i> Support & Enquiries</span>
        <h1>Get in Touch</h1>
        <p>We'd love to hear from you. Reach out and we'll respond as soon as possible.</p>
    </div>
</div>

<div class="contact-page">
    <div class="contact-layout">

        <!-- LEFT: Info -->
        <div class="contact-info">
            <div class="info-card">
                <div class="info-icon"><i class="fa-solid fa-location-dot"></i></div>
                <div>
                    <h4>Address</h4>
                    <p>Kigali, Rwanda</p>
                </div>
            </div>
            <div class="info-card">
                <div class="info-icon"><i class="fa-solid fa-phone"></i></div>
                <div>
                    <h4>Phone</h4>
                    <p>+250 791 375 079</p>
                </div>
            </div>
            <div class="info-card">
                <div class="info-icon"><i class="fa-solid fa-envelope"></i></div>
                <div>
                    <h4>Email</h4>
                    <p>info@grandhaven.com</p>
                </div>
            </div>
            <div class="info-card">
                <div class="info-icon"><i class="fa-solid fa-clock"></i></div>
                <div>
                    <h4>Reception Hours</h4>
                    <p>24 / 7 &mdash; Always open</p>
                </div>
            </div>

            <!-- Social Links -->
            <div class="contact-socials">
                <p>Follow Us</p>
                <div class="social-links">
                    <a href="#"><i class="fa-brands fa-facebook"></i></a>
                    <a href="#"><i class="fa-brands fa-instagram"></i></a>
                    <a href="#"><i class="fa-brands fa-x-twitter"></i></a>
                </div>
            </div>
        </div>

        <!-- RIGHT: Form -->
        <div class="contact-form-wrap">
            @if (Model.Sent)
            {
                <div class="contact-success">
                    <div class="success-icon"><i class="fa-solid fa-circle-check"></i></div>
                    <h3>Message Sent!</h3>
                    <p>Thank you for reaching out. We'll get back to you within 24 hours.</p>
                    <a href="/Index" class="success-btn"><i class="fa-solid fa-house"></i> Back to Home</a>
                </div>
            }
            else
            {
                <div class="form-card-header">
                    <h2><i class="fa-regular fa-paper-plane"></i> Send Us a Message</h2>
                    <p>Fill in the form and our team will be in touch shortly</p>
                </div>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="contact-error"><i class="fa-solid fa-circle-exclamation"></i> @Model.ErrorMessage</div>
                }

                <form method="post">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Full Name</label>
                            <div class="input-icon">
                                <i class="fa-regular fa-user"></i>
                                <input type="text" name="fullName" placeholder="" required />
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Email Address</label>
                            <div class="input-icon">
                                <i class="fa-regular fa-envelope"></i>
                                <input type="email" name="email" placeholder="" required />
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Subject</label>
                        <div class="input-icon">
                            <i class="fa-solid fa-tag"></i>
                            <input type="text" name="subject" placeholder="How can we help?" required />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Message</label>
                        <textarea name="message" rows="6" placeholder="Write your message here..." required></textarea>
                    </div>
                    <button type="submit" class="btn-send">
                        <i class="fa-solid fa-paper-plane"></i> Send Message
                    </button>
                </form>
            }
        </div>

    </div>
</div>

<!-- FOOTER -->
<footer class="contact-footer">
    <div class="footer-inner">
        <div class="footer-col">
            <h3><i class="fa-solid fa-hotel"></i> Grand Haven</h3>
            <p>Experience luxury and comfort in the heart of the city. Your perfect getaway awaits.</p>
        </div>
        <div class="footer-col">
            <h4>Contact</h4>
            <p><i class="fa-solid fa-phone"></i> +250 791 375 079</p>
            <p><i class="fa-solid fa-envelope"></i> info@grandhaven.com</p>
            <p><i class="fa-solid fa-location-dot"></i> Kigali, Rwanda</p>
        </div>
        <div class="footer-col">
            <h4>Quick Links</h4>
            <a href="/Index">Home</a>
            <a href="/Rooms">Our Rooms</a>
            <a href="/Events">Events</a>
            <a href="/Contact">Contact</a>
        </div>
    </div>
    <div class="footer-bottom">
        <p>&copy; 2026 Grand Haven Hotel. All rights reserved.</p>
    </div>
</footer>
