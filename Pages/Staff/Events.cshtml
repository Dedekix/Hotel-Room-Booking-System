@page
@model HotelBookingSystem.Pages.Staff.EventsModel
@{
    Layout = "_StaffLayout";
    ViewData["Title"] = "Events";
    ViewData["ActivePage"] = "Events";
    int totalBooked    = Model.Events.Sum(e => e.BookingCount);
    int totalAvailable = Model.Events.Sum(e => e.AvailableSpots);
    int freeEvents     = Model.Events.Count(e => e.Price == 0);
}

<!-- PAGE HEADER -->
<div class="dash-header">
    <div>
        <p class="dash-greeting">Admin Panel</p>
        <h1 class="staff-page-title">Event Management</h1>
        <p class="dash-date"><i class="fa-solid fa-calendar-star"></i> @Model.Events.Count event@(Model.Events.Count != 1 ? "s" : "") listed</p>
    </div>
    <button class="btn-add-room" onclick="openAddModal()">
        <i class="fa-solid fa-plus"></i> Add Event
    </button>
</div>

<!-- SUMMARY PILLS -->
<div class="rooms-summary">
    <div class="summary-pill summary-pill-blue">
        <i class="fa-solid fa-ticket"></i>
        <span>@totalBooked Total Reservations</span>
    </div>
    <div class="summary-pill summary-pill-green">
        <i class="fa-solid fa-users"></i>
        <span>@totalAvailable Spots Available</span>
    </div>
    <div class="summary-pill summary-pill-gold">
        <i class="fa-solid fa-gift"></i>
        <span>@freeEvents Free Event@(freeEvents != 1 ? "s" : "")</span>
    </div>
</div>

<!-- ALERTS -->
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="staff-alert staff-alert-error"><i class="fa-solid fa-circle-exclamation"></i> @Model.ErrorMessage</div>
}
@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="staff-alert staff-alert-success"><i class="fa-solid fa-circle-check"></i> @Model.SuccessMessage</div>
}

<!-- EVENTS GRID -->
<div class="rooms-mgmt-grid">
    @foreach (var ev in Model.Events)
    {
        int filledPercent = ev.Capacity > 0 ? (int)((double)ev.BookingCount / ev.Capacity * 100) : 0;

        <div class="room-mgmt-card event-mgmt-card">
            <!-- Image -->
            <div class="event-mgmt-img-wrap">
                <img src="/@ev.ImagePath?v=@DateTime.Now.Ticks" alt="@ev.Title" />
                <span class="event-mgmt-price-tag">
                    @(ev.Price == 0 ? "Free" : "$" + ev.Price.ToString("0.##"))
                </span>
            </div>

            <div class="room-mgmt-card-header" style="margin-top:4px">
                <span class="room-mgmt-number" style="font-size:15px">@ev.Title</span>
                <span class="badge-available"><i class="fa-solid fa-ticket"></i> @ev.BookingCount</span>
            </div>

            <div class="event-mgmt-meta">
                <span><i class="fa-regular fa-calendar"></i> @ev.EventDate.ToString("MMM d, yyyy h:mm tt")</span>
                <span><i class="fa-solid fa-location-dot"></i> @ev.Location</span>
            </div>

            <!-- Capacity bar -->
            <div class="event-capacity-wrap">
                <div class="event-capacity-bar-track">
                    <div class="event-capacity-bar-fill" style="width:@filledPercent%"></div>
                </div>
                <div class="event-capacity-labels">
                    <span class="capacity-booked">@ev.BookingCount booked</span>
                    <span class="capacity-available">@ev.AvailableSpots left</span>
                </div>
            </div>

            <div class="room-mgmt-actions">
                <button class="btn-edit"
                    onclick="openEditModal(@ev.EventId, '@Html.Raw(ev.Title.Replace("'", "\\'"))', '@Html.Raw(ev.Description.Replace("'", "\\'"))', '@ev.EventDate.ToString("yyyy-MM-ddTHH:mm")', '@Html.Raw(ev.Location.Replace("'", "\\'"))', @ev.Capacity, @ev.Price, '@ev.ImagePath')">
                    <i class="fa-solid fa-pen"></i> Edit
                </button>
                <form method="post" asp-page-handler="Delete" style="margin:0" id="del-form-@ev.EventId">
                    <input type="hidden" name="eventId" value="@ev.EventId" />
                    <button type="button" class="btn-toggle btn-toggle-maintenance"
                        onclick="ghConfirm(event, 'Delete &quot;@ev.Title&quot;? This cannot be undone.', () => document.getElementById('del-form-@ev.EventId').submit())">
                        <i class="fa-solid fa-trash"></i> Delete
                    </button>
                </form>
            </div>
        </div>
    }
</div>

<!-- ADD MODAL -->
<div class="modal-backdrop" id="addModal" style="display:none">
    <div class="modal-card">
        <div class="modal-header">
            <h3><i class="fa-solid fa-plus"></i> Add New Event</h3>
            <button class="modal-close" onclick="closeModal('addModal')">&times;</button>
        </div>
        <form method="post" asp-page-handler="Add" enctype="multipart/form-data">
            <div class="modal-body">
                <div class="mform-group">
                    <label>Title</label>
                    <input type="text" name="title" placeholder="Event title" required />
                </div>
                <div class="form-row-modal">
                    <div class="mform-group">
                        <label>Date &amp; Time</label>
                        <input type="datetime-local" name="eventDate" required />
                    </div>
                    <div class="mform-group">
                        <label>Location</label>
                        <input type="text" name="location" placeholder="e.g. Grand Hall" required />
                    </div>
                </div>
                <div class="form-row-modal">
                    <div class="mform-group">
                        <label>Capacity</label>
                        <input type="number" name="capacity" min="1" required />
                    </div>
                    <div class="mform-group">
                        <label>Price ($)</label>
                        <input type="number" name="price" min="0" step="0.01" value="0" required />
                    </div>
                </div>
                <div class="mform-group">
                    <label>Description</label>
                    <textarea name="description" rows="2" placeholder="Optional description"></textarea>
                </div>
                <div class="mform-group">
                    <label>Event Image</label>
                    <input type="file" name="imageFile" accept="image/*" required />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-modal-cancel" onclick="closeModal('addModal')">Cancel</button>
                <button type="submit" class="btn-modal-confirm"><i class="fa-solid fa-plus"></i> Add Event</button>
            </div>
        </form>
    </div>
</div>

<!-- CONFIRM EDIT DIALOG -->
<div class="modal-backdrop modal-backdrop-top" id="confirmEditModal" style="display:none">
    <div class="modal-card" style="max-width:400px">
        <div class="modal-header">
            <h3><i class="fa-solid fa-triangle-exclamation" style="color:#b07a2a"></i> Confirm Edit</h3>
            <button class="modal-close" onclick="closeModal('confirmEditModal')">&times;</button>
        </div>
        <div class="modal-body">
            <p style="font-size:14px;color:#555">Are you sure you want to save changes to <strong id="confirmEventTitle"></strong>?</p>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-modal-cancel" onclick="closeModal('confirmEditModal')">Cancel</button>
            <button type="button" class="btn-modal-confirm" onclick="document.getElementById('editForm').submit()">
                <i class="fa-solid fa-floppy-disk"></i> Confirm
            </button>
        </div>
    </div>
</div>

<!-- EDIT MODAL -->
<div class="modal-backdrop" id="editModal" style="display:none">
    <div class="modal-card">
        <div class="modal-header">
            <h3><i class="fa-solid fa-pen"></i> Edit Event</h3>
            <button class="modal-close" onclick="closeModal('editModal')">&times;</button>
        </div>
        <form method="post" asp-page-handler="Edit" enctype="multipart/form-data" id="editForm">
            <input type="hidden" name="eventId" id="editEventId" />
            <div class="modal-body">
                <div class="mform-group">
                    <label>Title</label>
                    <input type="text" name="title" id="editTitle" required />
                </div>
                <div class="form-row-modal">
                    <div class="mform-group">
                        <label>Date &amp; Time</label>
                        <input type="datetime-local" name="eventDate" id="editDate" required />
                    </div>
                    <div class="mform-group">
                        <label>Location</label>
                        <input type="text" name="location" id="editLocation" required />
                    </div>
                </div>
                <div class="form-row-modal">
                    <div class="mform-group">
                        <label>Capacity</label>
                        <input type="number" name="capacity" id="editCapacity" min="1" required />
                    </div>
                    <div class="mform-group">
                        <label>Price ($)</label>
                        <input type="number" name="price" id="editPrice" min="0" step="0.01" required />
                    </div>
                </div>
                <div class="mform-group">
                    <label>Description</label>
                    <textarea name="description" id="editDescription" rows="2"></textarea>
                </div>
                <div class="mform-group">
                    <label>Change Image <span style="color:#aaa;font-weight:400">(optional)</span></label>
                    <input type="file" name="imageFile" accept="image/*" />
                    <small style="color:#aaa;margin-top:4px;display:block">Current: <span id="editCurrentImage"></span></small>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-modal-cancel" onclick="closeModal('editModal')">Cancel</button>
                <button type="button" class="btn-modal-confirm" onclick="showEditConfirm()">
                    <i class="fa-solid fa-floppy-disk"></i> Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function openAddModal() { document.getElementById('addModal').style.display = 'flex'; }
    function closeModal(id) { document.getElementById(id).style.display = 'none'; }

    function openEditModal(id, title, desc, date, location, capacity, price, imagePath) {
        document.getElementById('editEventId').value      = id;
        document.getElementById('editTitle').value        = title;
        document.getElementById('editDescription').value  = desc;
        document.getElementById('editDate').value         = date;
        document.getElementById('editLocation').value     = location;
        document.getElementById('editCapacity').value     = capacity;
        document.getElementById('editPrice').value        = price;
        document.getElementById('editCurrentImage').textContent = imagePath;
        document.getElementById('editModal').style.display = 'flex';
    }

    function showEditConfirm() {
        document.getElementById('confirmEventTitle').textContent = document.getElementById('editTitle').value;
        document.getElementById('confirmEditModal').style.display = 'flex';
    }

    document.querySelectorAll('.modal-backdrop').forEach(el => {
        el.addEventListener('click', e => { if (e.target === el) closeModal(el.id); });
    });
</script>
}
