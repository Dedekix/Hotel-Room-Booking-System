@page
@model HotelBookingSystem.Pages.Staff.BookingsModel
@{
    Layout = "_StaffLayout";
    ViewData["Title"] = "Bookings";
    ViewData["ActivePage"] = "Bookings";
    int pending    = Model.Bookings.Count(b => b.Status == "PENDING");
    int confirmed  = Model.Bookings.Count(b => b.Status == "CONFIRMED");
    int checkedIn  = Model.Bookings.Count(b => b.Status == "CHECKED_IN");
    int completed  = Model.Bookings.Count(b => b.Status == "CHECKED_OUT" || b.Status == "COMPLETED");
    int cancelled  = Model.Bookings.Count(b => b.Status == "CANCELLED");
}

<!-- PAGE HEADER -->
<div class="dash-header">
    <div>
        <p class="dash-greeting">Personnel Portal</p>
        <h1 class="staff-page-title">All Bookings</h1>
        <p class="dash-date"><i class="fa-solid fa-list"></i> @Model.Bookings.Count total booking@(Model.Bookings.Count != 1 ? "s" : "")</p>
    </div>
    <div class="bookings-search-box">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" placeholder="Search guest or room..." id="searchInput" oninput="filterBookings()" />
    </div>
</div>

<!-- STATUS FILTER TABS -->
<div class="bookings-filter-tabs">
    <button class="b-filter-btn active" data-filter="all">
        All <span class="b-filter-count">@Model.Bookings.Count</span>
    </button>
    <button class="b-filter-btn" data-filter="PENDING">
        Pending <span class="b-filter-count">@pending</span>
    </button>
    <button class="b-filter-btn" data-filter="CONFIRMED">
        Confirmed <span class="b-filter-count">@confirmed</span>
    </button>
    <button class="b-filter-btn" data-filter="CHECKED_IN">
        Checked In <span class="b-filter-count">@checkedIn</span>
    </button>
    <button class="b-filter-btn" data-filter="COMPLETED">
        Completed <span class="b-filter-count">@completed</span>
    </button>
    <button class="b-filter-btn" data-filter="CANCELLED">
        Cancelled <span class="b-filter-count">@cancelled</span>
    </button>
</div>

<!-- TABLE -->
<div class="staff-table-wrap">
    <table class="staff-table" id="bookingsTable">
        <thead>
            <tr>
                <th>Booking</th>
                <th>Guest</th>
                <th>Room</th>
                <th>Check-in</th>
                <th>Check-out</th>
                <th>Total</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var b in Model.Bookings)
            {
                string badgeClass = b.Status switch
                {
                    "PENDING"     => "badge-pending",
                    "CHECKED_IN"  => "badge-checkedin",
                    "CONFIRMED"   => "badge-confirmed",
                    "CHECKED_OUT" => "badge-completed",
                    "COMPLETED"   => "badge-completed",
                    "CANCELLED"   => "badge-cancelled",
                    _             => "badge-confirmed"
                };
                string badgeLabel = b.Status switch
                {
                    "PENDING"     => "Pending",
                    "CHECKED_IN"  => "Checked In",
                    "CONFIRMED"   => "Confirmed",
                    "CHECKED_OUT" => "Completed",
                    "COMPLETED"   => "Completed",
                    "CANCELLED"   => "Cancelled",
                    _             => b.Status
                };
                <tr data-status="@b.Status" data-search="@b.GuestName.ToLower() @b.RoomNumber.ToLower()">
                    <td><span class="booking-id">B@(b.BookingId.ToString("D3"))</span></td>
                    <td>
                        <div class="table-guest">
                            <div class="table-avatar">@b.GuestName[0]</div>
                            <span>@b.GuestName</span>
                        </div>
                    </td>
                    <td><span class="table-room">Room @b.RoomNumber</span></td>
                    <td class="table-date">@b.CheckIn.ToString("MMM d, yyyy")</td>
                    <td class="table-date">@b.CheckOut.ToString("MMM d, yyyy")</td>
                    <td><span class="table-amount">$@b.TotalAmount.ToString("0.00")</span></td>
                    <td><span class="badge-status @badgeClass">@badgeLabel</span></td>
                    <td>
                        @if (b.Status == "PENDING")
                        {
                            <form method="post" asp-page-handler="Confirm" style="display:inline">
                                <input type="hidden" name="bookingId" value="@b.BookingId" />
                                <button class="action-btn action-btn-checkin"
                                    onclick="ghConfirm(event, 'Confirm booking for @b.GuestName (Room @b.RoomNumber)?', () => this.closest('form').submit())">
                                    <i class="fa-solid fa-circle-check"></i> Confirm
                                </button>
                            </form>
                        }
                        else if (b.Status == "CONFIRMED")
                        {
                            <form method="post" asp-page-handler="CheckIn" style="display:inline">
                                <input type="hidden" name="bookingId" value="@b.BookingId" />
                                <button class="action-btn action-btn-checkin"
                                    onclick="ghConfirm(event, 'Check in @b.GuestName (Room @b.RoomNumber)?', () => this.closest('form').submit())">
                                    <i class="fa-solid fa-right-to-bracket"></i> Check In
                                </button>
                            </form>
                        }
                        else if (b.Status == "CHECKED_IN")
                        {
                            <form method="post" asp-page-handler="CheckOut" style="display:inline">
                                <input type="hidden" name="bookingId" value="@b.BookingId" />
                                <button class="action-btn action-btn-checkout"
                                    onclick="ghConfirm(event, 'Check out @b.GuestName (Room @b.RoomNumber)?', () => this.closest('form').submit())">
                                    <i class="fa-solid fa-right-from-bracket"></i> Check Out
                                </button>
                            </form>
                        }
                        else
                        {
                            <span class="table-no-action">—</span>
                        }
                    </td>
                </tr>
            }
            @if (!Model.Bookings.Any())
            {
                <tr>
                    <td colspan="8" class="table-empty">
                        <i class="fa-regular fa-calendar-xmark"></i> No bookings found.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- PAGINATION -->
@if (Model.TotalPages > 1)
{
    <div class="pagination-bar">
        @if (Model.CurrentPage > 1)
        {
            <a href="?p=@(Model.CurrentPage - 1)" class="page-btn"><i class="fa-solid fa-chevron-left"></i></a>
        }
        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <a href="?p=@i" class="page-btn @(i == Model.CurrentPage ? "page-btn-active" : "")">@i</a>
        }
        @if (Model.CurrentPage < Model.TotalPages)
        {
            <a href="?p=@(Model.CurrentPage + 1)" class="page-btn"><i class="fa-solid fa-chevron-right"></i></a>
        }
        <span class="page-info">Page @Model.CurrentPage of @Model.TotalPages</span>
    </div>
}

@section Scripts {
<script>
    let activeFilter = 'all';

    function filterBookings() {
        const q = document.getElementById('searchInput').value.toLowerCase();
        document.querySelectorAll('#bookingsTable tbody tr[data-status]').forEach(row => {
            const matchSearch = row.dataset.search.includes(q);
            const matchFilter = activeFilter === 'all' || row.dataset.status === activeFilter
                || (activeFilter === 'COMPLETED' && (row.dataset.status === 'CHECKED_OUT' || row.dataset.status === 'COMPLETED'));
            row.style.display = matchSearch && matchFilter ? '' : 'none';
        });
    }
    document.querySelectorAll('.b-filter-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.b-filter-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            activeFilter = btn.dataset.filter;
            filterBookings();
        });
    });
</script>
}
