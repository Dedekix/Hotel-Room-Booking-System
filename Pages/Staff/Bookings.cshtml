@page
@model HotelBookingSystem.Pages.Staff.BookingsModel
@{
    Layout = "_StaffLayout";
    ViewData["Title"] = "Bookings";
    ViewData["ActivePage"] = "Bookings";
}

<div class="bookings-header">
    <h1 class="staff-page-title" style="margin-bottom:0">All Bookings</h1>
    <div class="search-box">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" placeholder="Search guest or room..." id="searchInput" oninput="filterBookings()" />
    </div>
</div>

<table class="bookings-table" id="bookingsTable">
    <thead>
        <tr>
            <th>Booking</th>
            <th>Guest</th>
            <th>Room</th>
            <th>Dates</th>
            <th>Total</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var b in Model.Bookings)
        {
            string badgeClass = b.Status switch
            {
                "CHECKED_IN" => "badge-checkedin",
                "CONFIRMED"  => "badge-confirmed",
                "COMPLETED"  => "badge-completed",
                _            => "badge-confirmed"
            };
            string badgeLabel = b.Status switch
            {
                "CHECKED_IN" => "Checked-In",
                "CONFIRMED"  => "Confirmed",
                "COMPLETED"  => "Completed",
                "CANCELLED"  => "Cancelled",
                _            => b.Status
            };

            <tr>
                <td class="booking-id">B@(b.BookingId.ToString("D3"))</td>
                <td class="guest-name">@b.GuestName</td>
                <td>@b.RoomNumber</td>
                <td>@b.CheckIn.ToString("yyyy-MM-dd") &rarr; @b.CheckOut.ToString("yyyy-MM-dd")</td>
                <td class="total-amount">$@b.TotalAmount.ToString("0")</td>
                <td><span class="badge-status @badgeClass">@badgeLabel</span></td>
                <td>
                    @if (b.Status == "CONFIRMED")
                    {
                        <form method="post" asp-page-handler="CheckIn" style="display:inline">
                            <input type="hidden" name="bookingId" value="@b.BookingId" />
                            <button class="action-link">Check In</button>
                        </form>
                    }
                    else if (b.Status == "CHECKED_IN")
                    {
                        <form method="post" asp-page-handler="CheckOut" style="display:inline">
                            <input type="hidden" name="bookingId" value="@b.BookingId" />
                            <button class="action-link">Check Out</button>
                        </form>
                    }
                </td>
            </tr>
        }
        @if (!Model.Bookings.Any())
        {
            <tr><td colspan="7" style="text-align:center;padding:32px;color:#aaa;">No bookings found.</td></tr>
        }
    </tbody>
</table>

@section Scripts {
<script>
    function filterBookings() {
        const q = document.getElementById('searchInput').value.toLowerCase();
        document.querySelectorAll('#bookingsTable tbody tr').forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    }
</script>
}
