@page
@model HotelBookingSystem.Pages.Staff.ReportsModel
@{
    Layout = "_StaffLayout";
    ViewData["Title"]      = "Reports";
    ViewData["ActivePage"] = "Reports";
    decimal maxRevenue = Model.RevenueByType.Any() ? Model.RevenueByType.Max(r => r.Revenue) : 1;
}

<!-- PAGE HEADER -->
<div class="dash-header">
    <div>
        <p class="dash-greeting">Admin Panel</p>
        <h1 class="staff-page-title">Reports & Analytics</h1>
        <p class="dash-date"><i class="fa-regular fa-calendar"></i> Generated @DateTime.Now.ToString("MMM d, yyyy h:mm tt")</p>
    </div>
    <div style="display:flex;gap:10px">
        <form method="post" asp-page-handler="ExportExcel">
            <button type="submit" class="export-btn export-btn-green">
                <i class="fa-solid fa-file-excel"></i> Export Excel
            </button>
        </form>
        <form method="post" asp-page-handler="ExportPdf">
            <button type="submit" class="export-btn export-btn-red">
                <i class="fa-solid fa-file-pdf"></i> Export PDF
            </button>
        </form>
    </div>
</div>

<!-- STAT CARDS -->
<div class="stats-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:32px">
    <div class="stat-card">
        <div class="stat-card-top">
            <div>
                <span class="stat-label">Total Revenue</span>
                <div class="stat-value">$@Model.TotalRevenue.ToString("N0")</div>
            </div>
            <div class="stat-icon orange"><i class="fa-solid fa-dollar-sign"></i></div>
        </div>
        <div class="stat-footer">
            <span class="stat-trend stat-trend-up"><i class="fa-solid fa-arrow-trend-up"></i> Confirmed & checked-in</span>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-card-top">
            <div>
                <span class="stat-label">Total Bookings</span>
                <div class="stat-value">@Model.TotalBookings</div>
            </div>
            <div class="stat-icon blue"><i class="fa-regular fa-calendar-check"></i></div>
        </div>
        <div class="stat-footer">
            <span class="stat-trend stat-trend-up"><i class="fa-solid fa-arrow-trend-up"></i> Excluding cancelled</span>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-card-top">
            <div>
                <span class="stat-label">Occupancy Rate</span>
                <div class="stat-value">@Model.OccupancyRate</div>
            </div>
            <div class="stat-icon yellow"><i class="fa-solid fa-chart-pie"></i></div>
        </div>
        <div class="stat-footer">
            <div class="occupancy-bar-wrap">
                <div class="occupancy-bar-track">
                    <div class="occupancy-bar-fill" style="width:@Model.OccupancyRate"></div>
                </div>
                <span class="occupancy-label">@Model.OccupiedRooms / @Model.TotalRooms rooms</span>
            </div>
        </div>
    </div>
</div>

<!-- REVENUE BY ROOM TYPE -->
<div class="dash-section-header" style="margin-bottom:16px">
    <h2 class="section-title"><i class="fa-solid fa-chart-bar"></i> Revenue by Room Type</h2>
</div>

<div class="revenue-list">
    @if (!Model.RevenueByType.Any())
    {
        <div class="table-empty"><i class="fa-solid fa-chart-bar"></i> No booking data available.</div>
    }
    else
    {
        @foreach (var r in Model.RevenueByType)
        {
            int barWidth = maxRevenue > 0 ? (int)(r.Revenue / maxRevenue * 100) : 0;
            <div class="revenue-item">
                <div class="revenue-item-left">
                    <div class="revenue-type-tag">@r.RoomType</div>
                    <div class="revenue-bar-wrap">
                        <div class="revenue-bar-track">
                            <div class="revenue-bar-fill" style="width:@barWidth%"></div>
                        </div>
                    </div>
                </div>
                <div class="revenue-item-right">
                    <span class="revenue-amount">$@r.Revenue.ToString("N2")</span>
                    <span class="revenue-count">@r.BookingCount booking@(r.BookingCount != 1 ? "s" : "")</span>
                </div>
            </div>
        }
    }
</div>
