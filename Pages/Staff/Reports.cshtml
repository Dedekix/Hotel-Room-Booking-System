@page
@model HotelBookingSystem.Pages.Staff.ReportsModel
@{
    Layout = "_StaffLayout";
    ViewData["Title"] = "Reports";
    ViewData["ActivePage"] = "Reports";
}

<h1 class="staff-page-title">Reports</h1>

<div class="reports-stats">
    <div class="stat-card">
        <div class="stat-card-top">
            <span class="stat-label">Total Revenue</span>
            <div class="stat-icon orange"><i class="fa-solid fa-chart-bar"></i></div>
        </div>
        <div class="stat-value">$3,720</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-top">
            <span class="stat-label">Total Bookings</span>
            <div class="stat-icon blue"><i class="fa-regular fa-calendar"></i></div>
        </div>
        <div class="stat-value">5</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-top">
            <span class="stat-label">Occupancy Rate</span>
            <div class="stat-icon green"><i class="fa-solid fa-bed"></i></div>
        </div>
        <div class="stat-value">17%</div>
    </div>
</div>

<h2 class="section-title">Revenue by Room Type</h2>
<div class="revenue-list">
    <div class="revenue-item">
        <div>
            <div class="revenue-type">Standard</div>
            <div class="revenue-count">2 bookings</div>
        </div>
        <div class="revenue-amount">$600</div>
    </div>
    <div class="revenue-item">
        <div>
            <div class="revenue-type">Deluxe</div>
            <div class="revenue-count">2 bookings</div>
        </div>
        <div class="revenue-amount">$1,320</div>
    </div>
    <div class="revenue-item">
        <div>
            <div class="revenue-type">Suite</div>
            <div class="revenue-count">1 booking</div>
        </div>
        <div class="revenue-amount">$1,800</div>
    </div>
</div>
