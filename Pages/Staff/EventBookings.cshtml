@page
@model HotelBookingSystem.Pages.Staff.EventBookingsModel
@{
    Layout = "_StaffLayout";
    ViewData["Title"] = "Event Bookings";
    ViewData["ActivePage"] = "EventBookings";
    int pending   = Model.Bookings.Count(b => b.Status == "PENDING");
    int confirmed = Model.Bookings.Count(b => b.Status == "CONFIRMED");
    int cancelled = Model.Bookings.Count(b => b.Status == "CANCELLED");
}

<!-- PAGE HEADER -->
<div class="dash-header">
    <div>
        <p class="dash-greeting">Personnel Portal</p>
        <h1 class="staff-page-title">Event Reservations</h1>
        <p class="dash-date"><i class="fa-solid fa-ticket"></i> @Model.Bookings.Count total reservation@(Model.Bookings.Count != 1 ? "s" : "")</p>
    </div>
    <div class="bookings-search-box">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" placeholder="Search guest or event..." id="searchInput" oninput="filterTable()" />
    </div>
</div>

<!-- SUMMARY PILLS -->
<div class="rooms-summary">
    <div class="summary-pill summary-pill-yellow">
        <i class="fa-solid fa-clock"></i>
        <span>@pending Pending</span>
    </div>
    <div class="summary-pill summary-pill-green">
        <i class="fa-solid fa-circle-check"></i>
        <span>@confirmed Confirmed</span>
    </div>
    <div class="summary-pill summary-pill-red">
        <i class="fa-solid fa-circle-xmark"></i>
        <span>@cancelled Cancelled</span>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="staff-alert staff-alert-success"><i class="fa-solid fa-circle-check"></i> @Model.SuccessMessage</div>
}

<!-- FILTER TABS -->
<div class="bookings-filter-tabs">
    <button class="b-filter-btn active" data-filter="all">
        All <span class="b-filter-count">@Model.Bookings.Count</span>
    </button>
    <button class="b-filter-btn" data-filter="PENDING">
        Pending <span class="b-filter-count">@pending</span>
    </button>
    <button class="b-filter-btn" data-filter="CONFIRMED">
        Confirmed <span class="b-filter-count">@confirmed</span>
    </button>
    <button class="b-filter-btn" data-filter="CANCELLED">
        Cancelled <span class="b-filter-count">@cancelled</span>
    </button>
</div>

<!-- TABLE -->
<div class="staff-table-wrap">
    <table class="staff-table" id="ebTable">
        <thead>
            <tr>
                <th>#</th>
                <th>Guest</th>
                <th>Event</th>
                <th>Event Date</th>
                <th>Location</th>
                <th>Price</th>
                <th>Booked At</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var b in Model.Bookings)
            {
                string badgeClass = b.Status switch
                {
                    "CONFIRMED" => "badge-checkedin",
                    "CANCELLED" => "badge-cancelled",
                    _           => "badge-pending"
                };
                string badgeLabel = b.Status switch
                {
                    "CONFIRMED" => "Confirmed",
                    "CANCELLED" => "Cancelled",
                    _           => "Pending"
                };
                <tr data-status="@b.Status" data-search="@b.GuestName.ToLower() @b.EventTitle.ToLower()">
                    <td><span class="booking-id">EB@(b.EventBookingId.ToString("D3"))</span></td>
                    <td>
                        <div class="table-guest">
                            <div class="table-avatar">@b.GuestName[0]</div>
                            <div>
                                <div style="font-weight:600;color:#1a1a1a;font-size:13.5px">@b.GuestName</div>
                                <div style="font-size:12px;color:#aaa">@b.GuestEmail</div>
                            </div>
                        </div>
                    </td>
                    <td style="font-weight:600;color:#1a1a1a;font-size:13.5px">@b.EventTitle</td>
                    <td class="table-date">@b.EventDate.ToString("MMM d, yyyy")</td>
                    <td class="table-date">@b.Location</td>
                    <td>
                        @if (b.Price == 0)
                        {
                            <span style="color:#1e8449;font-weight:700;font-size:13px">Free</span>
                        }
                        else
                        {
                            <span class="table-amount">$@b.Price.ToString("0.00")</span>
                        }
                    </td>
                    <td class="table-date">@b.BookedAt.ToString("MMM d, yyyy")</td>
                    <td><span class="badge-status @badgeClass">@badgeLabel</span></td>
                    <td>
                        @if (b.Status == "PENDING")
                        {
                            <form method="post" asp-page-handler="Confirm" id="confirm-@b.EventBookingId" style="margin:0">
                                <input type="hidden" name="eventBookingId" value="@b.EventBookingId" />
                                <input type="hidden" name="amount" value="@b.Price" />
                                <button type="button" class="btn-checkin"
                                    onclick="ghConfirm(event, 'Confirm in-person payment for @Html.Raw(b.GuestName.Replace("'", "&#39;"))?', () => document.getElementById('confirm-@b.EventBookingId').submit())">
                                    <i class="fa-solid fa-circle-check"></i> Confirm Payment
                                </button>
                            </form>
                        }
                        else
                        {
                            <span style="color:#ccc;font-size:12px">&mdash;</span>
                        }
                    </td>
                </tr>
            }
            @if (!Model.Bookings.Any())
            {
                <tr>
                    <td colspan="9" class="table-empty">
                        <i class="fa-regular fa-calendar-xmark"></i> No event reservations found.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- PAGINATION -->
@if (Model.TotalPages > 1)
{
    <div class="pagination-bar">
        @if (Model.CurrentPage > 1)
        {
            <a href="?p=@(Model.CurrentPage - 1)" class="page-btn"><i class="fa-solid fa-chevron-left"></i></a>
        }
        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <a href="?p=@i" class="page-btn @(i == Model.CurrentPage ? "page-btn-active" : "")">@i</a>
        }
        @if (Model.CurrentPage < Model.TotalPages)
        {
            <a href="?p=@(Model.CurrentPage + 1)" class="page-btn"><i class="fa-solid fa-chevron-right"></i></a>
        }
        <span class="page-info">Page @Model.CurrentPage of @Model.TotalPages</span>
    </div>
}

@section Scripts {
<script>
    let activeFilter = 'all';

    function filterTable() {
        const q = document.getElementById('searchInput').value.toLowerCase();
        document.querySelectorAll('#ebTable tbody tr[data-status]').forEach(row => {
            const matchSearch = row.dataset.search.includes(q);
            const matchFilter = activeFilter === 'all' || row.dataset.status === activeFilter;
            row.style.display = matchSearch && matchFilter ? '' : 'none';
        });
    }

    document.querySelectorAll('.b-filter-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.b-filter-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            activeFilter = btn.dataset.filter;
            filterTable();
        });
    });
</script>
}
