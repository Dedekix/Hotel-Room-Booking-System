@page
@model HotelBookingSystem.Pages.Staff.EventBookingsModel
@{
    Layout = "_StaffLayout";
    ViewData["Title"] = "Event Bookings";
    ViewData["ActivePage"] = "EventBookings";
    int booked    = Model.Bookings.Count(b => b.Status != "CANCELLED");
    int cancelled = Model.Bookings.Count(b => b.Status == "CANCELLED");
}

<!-- PAGE HEADER -->
<div class="dash-header">
    <div>
        <p class="dash-greeting">Personnel Portal</p>
        <h1 class="staff-page-title">Event Reservations</h1>
        <p class="dash-date"><i class="fa-solid fa-ticket"></i> @Model.Bookings.Count total reservation@(Model.Bookings.Count != 1 ? "s" : "")</p>
    </div>
    <div class="bookings-search-box">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" placeholder="Search guest or event..." id="searchInput" oninput="filterTable()" />
    </div>
</div>

<!-- SUMMARY PILLS -->
<div class="rooms-summary">
    <div class="summary-pill summary-pill-green">
        <i class="fa-solid fa-circle-check"></i>
        <span>@booked Active Reservation@(booked != 1 ? "s" : "")</span>
    </div>
    <div class="summary-pill summary-pill-red">
        <i class="fa-solid fa-circle-xmark"></i>
        <span>@cancelled Cancelled</span>
    </div>
</div>

<!-- FILTER TABS -->
<div class="bookings-filter-tabs">
    <button class="b-filter-btn active" data-filter="all">
        All <span class="b-filter-count">@Model.Bookings.Count</span>
    </button>
    <button class="b-filter-btn" data-filter="CONFIRMED">
        Booked <span class="b-filter-count">@booked</span>
    </button>
    <button class="b-filter-btn" data-filter="CANCELLED">
        Cancelled <span class="b-filter-count">@cancelled</span>
    </button>
</div>

<!-- TABLE -->
<div class="staff-table-wrap">
    <table class="staff-table" id="ebTable">
        <thead>
            <tr>
                <th>#</th>
                <th>Guest</th>
                <th>Event</th>
                <th>Event Date</th>
                <th>Location</th>
                <th>Price</th>
                <th>Booked At</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var b in Model.Bookings)
            {
                string badgeClass = b.Status == "CANCELLED" ? "badge-cancelled" : "badge-checkedin";
                string badgeLabel = b.Status == "CANCELLED" ? "Cancelled" : "Booked";
                <tr data-status="@b.Status" data-search="@b.GuestName.ToLower() @b.EventTitle.ToLower()">
                    <td><span class="booking-id">EB@(b.EventBookingId.ToString("D3"))</span></td>
                    <td>
                        <div class="table-guest">
                            <div class="table-avatar">@b.GuestName[0]</div>
                            <div>
                                <div style="font-weight:600;color:#1a1a1a;font-size:13.5px">@b.GuestName</div>
                                <div style="font-size:12px;color:#aaa">@b.GuestEmail</div>
                            </div>
                        </div>
                    </td>
                    <td style="font-weight:600;color:#1a1a1a;font-size:13.5px">@b.EventTitle</td>
                    <td class="table-date">@b.EventDate.ToString("MMM d, yyyy")</td>
                    <td class="table-date">@b.Location</td>
                    <td>
                        @if (b.Price == 0)
                        {
                            <span style="color:#1e8449;font-weight:700;font-size:13px">Free</span>
                        }
                        else
                        {
                            <span class="table-amount">$@b.Price.ToString("0.00")</span>
                        }
                    </td>
                    <td class="table-date">@b.BookedAt.ToString("MMM d, yyyy")</td>
                    <td><span class="badge-status @badgeClass">@badgeLabel</span></td>
                </tr>
            }
            @if (!Model.Bookings.Any())
            {
                <tr>
                    <td colspan="8" class="table-empty">
                        <i class="fa-regular fa-calendar-xmark"></i> No event reservations found.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script>
    let activeFilter = 'all';

    function filterTable() {
        const q = document.getElementById('searchInput').value.toLowerCase();
        document.querySelectorAll('#ebTable tbody tr[data-status]').forEach(row => {
            const matchSearch = row.dataset.search.includes(q);
            const matchFilter = activeFilter === 'all'
                || (activeFilter === 'CANCELLED' && row.dataset.status === 'CANCELLED')
                || (activeFilter === 'CONFIRMED' && row.dataset.status !== 'CANCELLED');
            row.style.display = matchSearch && matchFilter ? '' : 'none';
        });
    }

    document.querySelectorAll('.b-filter-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.b-filter-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            activeFilter = btn.dataset.filter;
            filterTable();
        });
    });
</script>
}
