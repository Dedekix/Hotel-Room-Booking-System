@page
@model MyBookingsModel
@{
    ViewData["Title"] = "My Bookings - Grand Haven";
}
@section Styles {
    <link rel="stylesheet" href="~/css/mybookings.css" />
}

<div class="bookings-hero">
    <div class="container">
        <h1>My Bookings</h1>
        <p>View and manage your reservations</p>
    </div>
</div>

<div class="bookings-container">
    @if (ViewData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            <span class="alert-icon">✓</span>
            <span>@ViewData["SuccessMessage"]</span>
        </div>
    }

    @if (ViewData["ErrorMessage"] != null)
    {
        <div class="alert alert-error">
            <span class="alert-icon">✗</span>
            <span>@ViewData["ErrorMessage"]</span>
        </div>
    }

    <!-- Sample Booking 1 - Confirmed -->
    <div class="booking-card">
        <div class="booking-card-header">
            <div class="booking-room-info">
                <h3>Room 101 — Standard</h3>
                <span class="booking-room-type type-standard">Standard Room</span>
            </div>
            <div>
                <span class="booking-status status-confirmed">✓ Confirmed</span>
            </div>
        </div>
        
        <div class="booking-details">
            <div class="booking-detail-item">
                <span class="detail-label">Booking Type</span>
                <span class="detail-value">Daily</span>
            </div>
            <div class="booking-detail-item">
                <span class="detail-label">Check-in</span>
                <span class="detail-value">April 15, 2026 <small>at 2:00 PM</small></span>
            </div>
            <div class="booking-detail-item">
                <span class="detail-label">Check-out</span>
                <span class="detail-value">April 17, 2026 <small>at 12:00 PM</small></span>
            </div>
            <div class="booking-detail-item">
                <span class="detail-label">Guests</span>
                <span class="detail-value">2 guests</span>
            </div>
            <div class="booking-detail-item">
                <span class="detail-label">Duration</span>
                <span class="detail-value">2 nights</span>
            </div>
            <div class="booking-detail-item">
                <span class="detail-label">Total Price</span>
                <span class="detail-value booking-price">$240</span>
            </div>
        </div>
        
        <div class="booking-actions">
            <button class="btn-cancel" onclick="confirmCancel(1)">Cancel Booking</button>
            <a href="/Booking/101" class="btn-view">View Details</a>
        </div>
    </div>

    <!-- Sample Booking 2 - Confirmed -->
    <div class="booking-card">
        <div class="booking-card-header">
            <div class="booking-room-info">
                <h3>Room 201 — Deluxe</h3>
                <span class="booking-room-type type-deluxe">Deluxe Room</span>
            </div>
            <div>
                <span class="booking-status status-confirmed">✓ Confirmed</span>
            </div>
        </div>
        
        <div class="booking-details">
            <div class="booking-detail-item">
                <span class="detail-label">Booking Type</span>
                <span class="detail-value">Daily</span>
            </div>
            <div class="booking-detail-item">
                <span class="detail-label">Check-in</span>
                <span class="detail-value">April 20, 2026 <small>at 2:00 PM</small></span>
            </div>
            <div class="booking-detail-item">
                <span class="detail-label">Check-out</span>
                <span class="detail-value">April 22, 2026 <small>at 12:00 PM</small></span>
            </div>
            <div class="booking-detail-item">
                <span class="detail-label">Guests</span>
                <span class="detail-value">3 guests</span>
            </div>
            <div class="booking-detail-item">
                <span class="detail-label">Duration</span>
                <span class="detail-value">2 nights</span>
            </div>
            <div class="booking-detail-item">
                <span class="detail-label">Total Price</span>
                <span class="detail-value booking-price">$440</span>
            </div>
        </div>
        
        <div class="booking-actions">
            <button class="btn-cancel" onclick="confirmCancel(2)">Cancel Booking</button>
            <a href="/Booking" class="btn-view">View Details</a>
        </div>
    </div>

    <!-- Sample Booking 3 - Hourly Booking -->
    <div class="booking-card">
        <div class="booking-card-header">
            <div class="booking-room-info">
                <h3>Room 102 — Standard</h3>
                <span class="booking-room-type type-standard">Standard Room</span>
            </div>
            <div>
                <span class="booking-status status-confirmed">✓ Confirmed</span>
            </div>
        </div>
        
        <div class="booking-details">
            <div class="booking-detail-item">
                <span class="detail-label">Booking Type</span>
                <span class="detail-value">Hourly</span>
            </div>
            <div class="booking-detail-item">
                <span class="detail-label">Check-in</span>
                <span class="detail-value">April 25, 2026 <small>at 10:00 AM</small></span>
            </div>
            <div class="booking-detail-item">
                <span class="detail-label">Check-out</span>
                <span class="detail-value">April 25, 2026 <small>at 2:00 PM</small></span>
            </div>
            <div class="booking-detail-item">
                <span class="detail-label">Guests</span>
                <span class="detail-value">2 guests</span>
            </div>
            <div class="booking-detail-item">
                <span class="detail-label">Duration</span>
                <span class="detail-value">4 hours</span>
            </div>
            <div class="booking-detail-item">
                <span class="detail-label">Total Price</span>
                <span class="detail-value booking-price">$80</span>
            </div>
        </div>
        
        <div class="booking-actions">
            <button class="btn-cancel" onclick="confirmCancel(3)">Cancel Booking</button>
            <a href="/Booking" class="btn-view">View Details</a>
        </div>
    </div>

    <!-- Sample Booking 4 - Checked Out -->
    <div class="booking-card">
        <div class="booking-card-header">
            <div class="booking-room-info">
                <h3>Room 301 — Suite</h3>
                <span class="booking-room-type type-suite">Suite</span>
            </div>
            <div>
                <span class="booking-status status-checkedout">✓ Checked Out</span>
            </div>
        </div>
        
        <div class="booking-details">
            <div class="booking-detail-item">
                <span class="detail-label">Booking Type</span>
                <span class="detail-value">Daily</span>
            </div>
            <div class="booking-detail-item">
                <span class="detail-label">Check-in</span>
                <span class="detail-value">April 1, 2026 <small>at 2:00 PM</small></span>
            </div>
            <div class="booking-detail-item">
                <span class="detail-label">Check-out</span>
                <span class="detail-value">April 3, 2026 <small>at 12:00 PM</small></span>
            </div>
            <div class="booking-detail-item">
                <span class="detail-label">Guests</span>
                <span class="detail-value">4 guests</span>
            </div>
            <div class="booking-detail-item">
                <span class="detail-label">Duration</span>
                <span class="detail-value">2 nights</span>
            </div>
            <div class="booking-detail-item">
                <span class="detail-label">Total Price</span>
                <span class="detail-value booking-price">$900</span>
            </div>
        </div>
        
        <div class="booking-actions">
            <a href="/Booking" class="btn-view">View Details</a>
        </div>
    </div>

    <!-- Empty State (hidden by default, show when no bookings) -->
    <!--
    <div class="empty-state">
        <div class="empty-icon">📅</div>
        <h3>No Bookings Yet</h3>
        <p>You haven't made any room reservations yet.</p>
        <a href="/Rooms" class="btn-browse">Browse Rooms →</a>
    </div>
    -->
</div>

@section Scripts {
    <script>
        function confirmCancel(bookingId) {
            if (confirm('Are you sure you want to cancel this booking?')) {
                // In a real app, you would submit a form or make an AJAX call here
                alert('Booking #' + bookingId + ' has been cancelled.');
                location.reload();
            }
        }
    </script>
}