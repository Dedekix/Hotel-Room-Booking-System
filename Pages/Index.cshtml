@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}
<link rel="stylesheet" href="~/css/Home.css" />

<!-- HERO SECTION -->
<div class="hero">
    <div class="hero-overlay">
        <div class="hero-content">
            <span class="hero-tag"><i class="fa-solid fa-star"></i> Luxury Hotel Experience</span>
            <h1>Welcome to <span>Grand Haven</span></h1>
            <p>Discover unparalleled luxury and comfort in the heart of the city.<br/>Book by the hour or by the night — your perfect stay awaits.</p>
            <div class="hero-buttons">
                <a href="/Rooms" class="hero-btn-primary"><i class="fa-solid fa-bed"></i> Browse Rooms</a>
                <a href="/Events" class="hero-btn-secondary"><i class="fa-solid fa-calendar-star"></i> View Events</a>
            </div>
        </div>
        <div class="hero-stats">
            <div class="hero-stat"><span>200+</span><p>Rooms</p></div>
            <div class="hero-stat-divider"></div>
            <div class="hero-stat"><span>4.9★</span><p>Rating</p></div>
            <div class="hero-stat-divider"></div>
            <div class="hero-stat"><span>24/7</span><p>Support</p></div>
        </div>
    </div>
</div>

<!-- WHY CHOOSE US -->
<div class="features-section">
    <div class="section-header">
        <span class="section-tag">Why Grand Haven</span>
        <h2>Everything You Need for a Perfect Stay</h2>
    </div>
    <div class="features-grid">
        <div class="feature-card">
            <div class="feature-icon"><i class="fa-solid fa-calendar-check"></i></div>
            <h4>Easy Booking</h4>
            <p>Book your stay in just a few clicks with real-time availability.</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon"><i class="fa-solid fa-star"></i></div>
            <h4>Premium Rooms</h4>
            <p>From cozy standards to lavish suites — every room is exceptional.</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon"><i class="fa-solid fa-shield-halved"></i></div>
            <h4>Secure Payments</h4>
            <p>Your transactions are protected with industry-grade security.</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon"><i class="fa-solid fa-clock"></i></div>
            <h4>Hourly & Daily</h4>
            <p>Flexible booking options to fit any schedule or budget.</p>
        </div>
    </div>
</div>

<!-- EVENTS -->
<div class="events-section">
    <div class="events-intro">
        <h2>Upcoming Events at Grand Haven</h2>
        <p>Life at Grand Haven goes beyond a comfortable stay. From jaw-dropping talent shows and vibrant culture nights to serene spa retreats and glamorous anniversary galas — there's always something extraordinary happening here.
            Whether you're a guest or a local, reserve your spot and be part of the magic.</p>
    </div>

    <div class="events-grid">
        @foreach (var ev in Model.Events)
        {
            <div class="event-card">
                <img src="/@ev.ImagePath?v=@DateTime.Now.Ticks" alt="@ev.Title" />
                <div class="event-body">
                    <span class="event-badge">@ev.Badge</span>
                    <h3>@ev.Title</h3>
                    <p class="event-date"><i class="fa-regular fa-calendar"></i> @ev.EventDate</p>
                    <p class="event-desc">@ev.Description</p>
                    <div class="event-meta">
                        <span><i class="fa-solid fa-location-dot"></i> @ev.Location</span>
                        <span><i class="fa-solid fa-users"></i> @ev.Capacity seats</span>
                    </div>
                    <button class="btn-reserve" onclick="openModal(@ev.EventId, '@ev.Title', '@ev.EventDate')">Reserve a Spot</button>
                </div>
            </div>
        }
    </div>
</div>

<!-- RESERVATION MODAL -->
<div class="modal-backdrop" id="reserveModal">
    <div class="modal-box">
        <button class="modal-close" onclick="closeModal()">&times;</button>
        <h2>Reserve a Spot</h2>
        <p class="modal-event-name"><i class="fa-regular fa-calendar"></i> <span id="modalEventName"></span> &mdash; <span id="modalEventDate"></span></p>
        <form id="reserveForm">
            <input type="hidden" name="eventName" id="hiddenEventName" />
            <div class="form-group">
                <label>Full Name</label>
                <input type="text" name="fullName" placeholder="" required />
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" placeholder="" required />
            </div>
            <div class="form-group">
                <label>Phone</label>
                <input type="tel" name="phone" placeholder="" />
            </div>
            <button type="submit" class="btn-confirm-reserve">Confirm Reservation</button>
        </form>
        <div class="reserve-success" id="reserveSuccess" style="display:none">
            <i class="fa-solid fa-circle-check"></i> Your spot has been reserved!
        </div>
    </div>
</div>
<!-- FEATURED ROOMS -->
<div class="rooms-section">
    <div class="section-header">
        <span class="section-tag">Our Rooms</span>
        <h2>Featured Rooms</h2>
        <p>Handpicked selections for an unforgettable stay</p>
    </div>
    <div class="room-grid">
        <div class="room-card">
            <div class="room-img-wrap">
                <img src="/Images/Single room.jpg" alt="Room 101" />
                <span class="room-badge">Single</span>
            </div>
            <div class="room-info">
                <div class="room-info-top">
                    <h4>Room 101</h4>
                    <span class="room-price">$120<small>/night</small></span>
                </div>
                <p><i class="fa-solid fa-user"></i> 1 Guest &nbsp; <i class="fa-solid fa-expand"></i> 22m²</p>
                <a href="/Rooms" class="room-btn">View Room</a>
            </div>
        </div>
        <div class="room-card">
            <div class="room-img-wrap">
                <img src="/Images/room201.jpg" alt="Room 102" />
                <span class="room-badge">Double</span>
            </div>
            <div class="room-info">
                <div class="room-info-top">
                    <h4>Room 102</h4>
                    <span class="room-price">$120<small>/night</small></span>
                </div>
                <p><i class="fa-solid fa-users"></i> 2 Guests &nbsp; <i class="fa-solid fa-expand"></i> 30m²</p>
                <a href="/Rooms" class="room-btn">View Room</a>
            </div>
        </div>
        <div class="room-card">
            <div class="room-img-wrap">
                <img src="/Images/room301.jpg" alt="Room 201" />
                <span class="room-badge room-badge-gold">Suite</span>
            </div>
            <div class="room-info">
                <div class="room-info-top">
                    <h4>Room 201</h4>
                    <span class="room-price">$220<small>/night</small></span>
                </div>
                <p><i class="fa-solid fa-users"></i> 4 Guests &nbsp; <i class="fa-solid fa-expand"></i> 55m²</p>
                <a href="/Rooms" class="room-btn">View Room</a>
            </div>
        </div>
    </div>
    <div style="text-align:center;margin-top:40px">
        <a href="/Rooms" class="see-all-btn">See All Rooms <i class="fa-solid fa-arrow-right"></i></a>
    </div>
</div>

<!-- FOOTER -->
<footer class="footer">
    <div class="footer-inner">
        <div class="footer-col">
            <h3><i class="fa-solid fa-hotel"></i> Grand Haven</h3>
            <p>Experience luxury and comfort in the heart of the city. Your perfect getaway awaits.</p>
            <div class="footer-socials">
                <a href="#"><i class="fa-brands fa-facebook"></i></a>
                <a href="#"><i class="fa-brands fa-instagram"></i></a>
                <a href="#"><i class="fa-brands fa-x-twitter"></i></a>
            </div>
        </div>
        <div class="footer-col">
            <h4>Contact</h4>
            <p><i class="fa-solid fa-phone"></i> +250 791 375 079</p>
            <p><i class="fa-solid fa-envelope"></i> info@grandhaven.com</p>
            <p><i class="fa-solid fa-location-dot"></i> Kigali, Rwanda</p>
        </div>
        <div class="footer-col">
            <h4>Quick Links</h4>
            <a href="/Rooms">Rooms</a>
            <a href="/Events">Events</a>
            <a href="/Contact">Contact</a>
            <a href="/Login">Login</a>
        </div>
    </div>
    <div class="footer-bottom">
        <p>© 2026 Grand Haven Hotel. All rights reserved.</p>
    </div>
</footer>

@section Scripts {
<script>
    var isLoggedIn = @(Model.IsLoggedIn ? "true" : "false");

    function openModal(eventId, name, date) {
        if (!isLoggedIn) {
            window.location.href = '/Login';
            return;
        }
        document.getElementById('modalEventName').textContent = name;
        document.getElementById('modalEventDate').textContent = date;
        document.getElementById('hiddenEventName').value      = name;
        document.getElementById('reserveModal').classList.add('open');
    }
    function closeModal() {
        document.getElementById('reserveModal').classList.remove('open');
    }
    document.getElementById('reserveModal').addEventListener('click', function (e) {
        if (e.target === this) closeModal();
    });
    document.getElementById('reserveForm').addEventListener('submit', function (e) {
        e.preventDefault();
        this.style.display = 'none';
        document.getElementById('reserveSuccess').style.display = 'flex';
    });
</script>
}
