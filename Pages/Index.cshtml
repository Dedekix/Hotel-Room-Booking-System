@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}
<link rel="stylesheet" href="~/css/Home.css" />

<!-- HERO SECTION -->
<div class="hero">
    <div class="overlay">
        <h1>Welcome to <span>Grand Haven</span></h1>
        <p>Discover unparalleled luxury and comfort. Book by the hour or by the night.</p>
        <img src="/Images/hero-hotel.jpg" />

        <div class="buttons">
            <button class="btn-primary">Browse Rooms</button>
            <button class="btn-secondary">Login</button>
        </div>
    </div>
</div>

<!-- WHY CHOOSE US -->
<div class="section">
    <h2>Why Choose Us</h2>

    <div class="grid">
        <div class="card">
            <i class="fa-solid fa-calendar icon"></i>
            <h4>Easy Booking</h4>
            <p>Book your stay in just a few clicks with real-time availability.</p>
        </div>

        <div class="card">
            <i class="fa-solid fa-star icon"></i>
            <h4>Premium Rooms</h4>
            <p>From standard to luxury suites.</p>
        </div>

        <div class="card">
            <i class="fa-solid fa-shield-halved icon"></i>
            <h4>Secure Payments</h4>
            <p>Protected with industry security.</p>
        </div>

        <div class="card">
            <i class="fa-solid fa-clock icon"></i>
            <h4>Hourly & Daily</h4>
            <p>Flexible booking options.</p>
        </div>
    </div>
</div>

<!-- EVENTS -->
<div class="events-section">
    <div class="events-intro">
        <h2>Upcoming Events at Grand Haven</h2>
        <p>Life at Grand Haven goes beyond a comfortable stay. From jaw-dropping talent shows and vibrant culture nights to serene spa retreats and glamorous anniversary galas — there's always something extraordinary happening here.
            Whether you're a guest or a local, reserve your spot and be part of the magic.</p>
    </div>

    <div class="events-grid">
        <div class="event-card">
            <img src="/Images/talent.jpg" alt="Talent Show" />
            <div class="event-body">
                <span class="event-badge">Weekly</span>
                <h3>Talent Show</h3>
                <p class="event-date"><i class="fa-regular fa-calendar"></i> Every Friday &mdash; 7:00 PM</p>
                <p class="event-desc">Watch incredible performances from talented local artists — singers, dancers, comedians and more. A night of fun for everyone.</p>
                <div class="event-meta">
                    <span><i class="fa-solid fa-location-dot"></i> Grand Hall</span>
                    <span><i class="fa-solid fa-users"></i> 200 seats</span>
                </div>
                <button class="btn-reserve" onclick="openModal('Talent Show', 'Every Friday — 7:00 PM')">Reserve</button>
            </div>
        </div>

        <div class="event-card">
            <img src="/Images/culture.jpg" alt="Culture Festival" />
            <div class="event-body">
                <span class="event-badge">May</span>
                <h3>Culture Festival</h3>
                <p class="event-date"><i class="fa-regular fa-calendar"></i> May 12&ndash;13, 2026</p>
                <p class="event-desc">Celebrate the richness of local culture through traditional music, dance, food and art. An immersive evening you won't forget.</p>
                <div class="event-meta">
                    <span><i class="fa-solid fa-location-dot"></i> Outdoor Terrace</span>
                    <span><i class="fa-solid fa-users"></i> 300 seats</span>
                </div>
                <button class="btn-reserve" onclick="openModal('Culture Night', 'April 12–13, 2026')">Reserve</button>
            </div>
        </div>

        <div class="event-card">
            <img src="/Images/event-spa.jpg" alt="Spa Retreat" />
            <div class="event-body">
                <span class="event-badge">Every Month</span>
                <h3>Spa Retreat</h3>
                <p class="event-date"><i class="fa-regular fa-calendar"></i> Every Month 18&ndash;20</p>
                <p class="event-desc">Escape the everyday with a full weekend of massages, aromatherapy, and wellness treatments in our world-class spa.</p>
                <div class="event-meta">
                    <span><i class="fa-solid fa-location-dot"></i> Wellness Centre</span>
                    <span><i class="fa-solid fa-users"></i> 50 seats</span>
                </div>
                <button class="btn-reserve" onclick="openModal('Spa Retreat', 'April 18–20, 2026')">Reserve</button>
            </div>
        </div>

        <div class="event-card">
            <img src="/Images/event-gala.jpg" alt="Anniversary Gala" />
            <div class="event-body">
                <span class="event-badge">May</span>
                <h3>Anniversary Gala</h3>
                <p class="event-date"><i class="fa-regular fa-calendar"></i> May 1, 2026</p>
                <p class="event-desc">Join us for a black-tie celebration marking Grand Haven's anniversary — live performances, gourmet dinner, and dancing.</p>
                <div class="event-meta">
                    <span><i class="fa-solid fa-location-dot"></i> Ballroom</span>
                    <span><i class="fa-solid fa-users"></i> 150 seats</span>
                </div>
                <button class="btn-reserve" onclick="openModal('Anniversary Gala', 'May 1, 2026')">Reserve</button>
            </div>
        </div>
    </div>
</div>

<!-- RESERVATION MODAL -->
<div class="modal-backdrop" id="reserveModal">
    <div class="modal-box">
        <button class="modal-close" onclick="closeModal()">&times;</button>
        <h2>Reserve a Spot</h2>
        <p class="modal-event-name"><i class="fa-regular fa-calendar"></i> <span id="modalEventName"></span> &mdash; <span id="modalEventDate"></span></p>
        <form id="reserveForm">
            <input type="hidden" name="eventName" id="hiddenEventName" />
            <div class="form-group">
                <label>Full Name</label>
                <input type="text" name="fullName" placeholder="" required />
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" placeholder="" required />
            </div>
            <div class="form-group">
                <label>Phone</label>
                <input type="tel" name="phone" placeholder="" />
            </div>
            <button type="submit" class="btn-confirm-reserve">Confirm Reservation</button>
        </form>
        <div class="reserve-success" id="reserveSuccess" style="display:none">
            <i class="fa-solid fa-circle-check"></i> Your spot has been reserved!
        </div>
    </div>
</div>
<!-- ROOMS -->
<div class="section">
    <h2>Featured Rooms</h2>

    <div class="room-grid">
        <div class="room-card">
            <img src="/Images/room101.jpg" />
            <div class="content">
                <h4>Room 101</h4>
                <p>$120/night</p>
                <button>Book Now</button>
            </div>
        </div>

        <div class="room-card">
            <img src="/Images/room201.jpg" />
            <div class="content">
                <h4>Room 102</h4>
                <p>$120/night</p>
                <button>Book Now</button>
            </div>
        </div>

        <div class="room-card">
            <img src="/Images/room301.jpg" />
            <div class="content">
                <h4>Room 201</h4>
                <p>$220/night</p>
                <button>Book Now</button>
            </div>
        </div>
    </div>
</div>

<!-- FOOTER -->
<div class="footer">
    <div class="footer-col">
        <h3>🏨 Grand Haven</h3>
        <p>Experience luxury and comfort in the heart of the city. Your perfect getaway awaits.</p>
    </div>

    <div class="footer-col">
        <h4>Contact</h4>
        <p>+250791375079</p>
        <p>info@grandhaven.com</p>
        <p>Kigali,Rwanda</p>
    </div>

    <div class="footer-col">
        <h4>Quick Links</h4>
        <p><a href="#">About Us</a></p>
        <p><a href="/Rooms">Rooms</a></p>
        <p><a href="/Events">Events</a></p>
        <p><a href="/Contact">Contact</a></p>
    </div>
</div>

<div class="footer-bottom">
    <p>© 2026 Grand Haven Hotel. All rights reserved.</p>
</div>

@section Scripts {
<script>
    var isLoggedIn = @(Model.IsLoggedIn ? "true" : "false");

    function openModal(name, date) {
        if (!isLoggedIn) {
            window.location.href = '/Login';
            return;
        }
        document.getElementById('modalEventName').textContent = name;
        document.getElementById('modalEventDate').textContent = date;
        document.getElementById('hiddenEventName').value      = name;
        document.getElementById('reserveModal').classList.add('open');
    }
    function closeModal() {
        document.getElementById('reserveModal').classList.remove('open');
    }
    document.getElementById('reserveModal').addEventListener('click', function (e) {
        if (e.target === this) closeModal();
    });
    document.getElementById('reserveForm').addEventListener('submit', function (e) {
        e.preventDefault();
        this.style.display = 'none';
        document.getElementById('reserveSuccess').style.display = 'flex';
    });
</script>
}
