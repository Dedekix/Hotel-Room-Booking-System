@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}
<link rel="stylesheet" href="~/css/Home.css" />

<!-- HERO SECTION -->
<div class="hero">
    <div class="overlay">
        <h1>Welcome to <span>Grand Haven</span></h1>
        <p>Discover unparalleled luxury and comfort. Book by the hour or by the night.</p>
        <img src="/Images/hero-hotel.jpg" />

        <div class="buttons">
            <button class="btn-primary">Browse Rooms</button>
            <button class="btn-secondary">Login</button>
        </div>
    </div>
</div>

<!-- WHY CHOOSE US -->
<div class="section">
    <h2>Why Choose Us</h2>

    <div class="grid">
        <div class="card">
            <i class="fa-solid fa-calendar icon"></i>
            <h4>Easy Booking</h4>
            <p>Book your stay in just a few clicks with real-time availability.</p>
        </div>

        <div class="card">
            <i class="fa-solid fa-star icon"></i>
            <h4>Premium Rooms</h4>
            <p>From standard to luxury suites.</p>
        </div>

        <div class="card">
            <i class="fa-solid fa-shield-halved icon"></i>
            <h4>Secure Payments</h4>
            <p>Protected with industry security.</p>
        </div>

        <div class="card">
            <i class="fa-solid fa-clock icon"></i>
            <h4>Hourly & Daily</h4>
            <p>Flexible booking options.</p>
        </div>
    </div>
</div>

<!-- EVENTS -->
<div class="events-section">
    <div class="events-intro">
        <h2>Upcoming Events at Grand Haven</h2>
        <p>Life at Grand Haven goes beyond a comfortable stay. From jaw-dropping talent shows and vibrant culture nights to serene spa retreats and glamorous anniversary galas — there's always something extraordinary happening here. 
            Whether you're a guest or a local, reserve your spot and be part of the magic.</p>
    </div>

    <div class="events-grid">
        <div class="event-card">
            <img src="/Images/talent.jpg" alt="Talent Show" />
            <div class="event-card-body">
                <i class="fa-solid fa-star icon"></i>
                <h4>Talent Show</h4>
                <p class="event-date"><i class="fa-regular fa-calendar"></i> Every Friday &mdash; 7:00 PM</p>
                <p>Watch incredible performances from talented local artists — singers, dancers, comedians and more. A night of fun for everyone.</p>
                <button class="btn-event">Reserve a Spot</button>
            </div>
        </div>

        <div class="event-card">
            <img src="/Images/culture.jpg" alt="Wine & Dine Weekend" />
            <div class="event-card-body">
                <i class="fa-solid fa-masks-theater icon"></i>
                <h4>Culture Night</h4>
                <p class="event-date"><i class="fa-regular fa-calendar"></i> April 12&ndash;13, 2026</p>
                <p>Celebrate the richness of local culture through traditional music, dance, food and art. An immersive evening you won't forget.</p>
                <button class="btn-event">Reserve a Spot</button>
            </div>
        </div>

        <div class="event-card">
            <img src="/Images/event-spa.jpg" alt="Spa Retreat" />
            <div class="event-card-body">
                <i class="fa-solid fa-spa icon"></i>
                <h4>Spa Retreat</h4>
                <p class="event-date"><i class="fa-regular fa-calendar"></i> April 18&ndash;20, 2026</p>
                <p>Escape the everyday with a full weekend of massages, aromatherapy, and wellness treatments in our world-class spa.</p>
                <button class="btn-event">Reserve a Spot</button>
            </div>
        </div>

        <div class="event-card">
            <img src="/Images/event-gala.jpg" alt="Anniversary Gala" />
            <div class="event-card-body">
                <i class="fa-solid fa-cake-candles icon"></i>
                <h4>Anniversary Gala</h4>
                <p class="event-date"><i class="fa-regular fa-calendar"></i> May 1, 2026</p>
                <p>Join us for a black-tie celebration marking Grand Haven's anniversary — live performances, gourmet dinner, and dancing.</p>
                <button class="btn-event">Reserve a Spot</button>
            </div>
        </div>
    </div>
</div>
<!-- ROOMS -->
<div class="section">
    <h2>Featured Rooms</h2>

    <div class="room-grid">
        <div class="room-card">
            <img src="/Images/room101.jpg" />
            <div class="content">
                <h4>Room 101</h4>
                <p>$120/night</p>
                <button>Book Now</button>
            </div>
        </div>

        <div class="room-card">
            <img src="/Images/room201.jpg" />
            <div class="content">
                <h4>Room 102</h4>
                <p>$120/night</p>
                <button>Book Now</button>
            </div>
        </div>

        <div class="room-card">
            <img src="/Images/room301.jpg" />
            <div class="content">
                <h4>Room 201</h4>
                <p>$220/night</p>
                <button>Book Now</button>
            </div>
        </div>
    </div>
</div>

<!-- FOOTER -->
<div class="footer">
    <div class="footer-col">
        <h3>🏨 Grand Haven</h3>
        <p>Experience luxury and comfort in the heart of the city. Your perfect getaway awaits.</p>
    </div>

    <div class="footer-col">
        <h4>Contact</h4>
        <p>+250791375079</p>
        <p>info@grandhaven.com</p>
        <p>Kigali,Rwanda</p>
    </div>

    <div class="footer-col">
        <h4>Quick Links</h4>
        <p>About Us</p>
        <p>Our Rooms</p>
        <p>Privacy Policy</p>
    </div>
</div>

<div class="footer-bottom">
    <p>© 2026 Grand Haven Hotel. All rights reserved.</p>
</div>
