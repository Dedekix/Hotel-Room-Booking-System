@page
@{
    ViewData["Title"] = "Book Room - Grand Haven";
}
@section Styles {
    <link rel="stylesheet" href="~/css/booking.css" />
}

<div class="booking-container">
    <div class="booking-grid">
        <div class="room-info-card">
            <span class="room-badge">Deluxe</span>
            <h2>Room 202</h2>
            <p class="room-desc">Spacious deluxe room with stunning city views and premium furnishings.</p>

            <div class="amenities-list">
                <span class="amenity-item">📶 Wi-Fi</span>
                <span class="amenity-item">📺 TV</span>
                <span class="amenity-item">❄️ Air Conditioning</span>
                <span class="amenity-item">🍸 Mini Bar</span>
            </div>

            <div class="pricing">
                <div class="price-night">
                    <span class="price-label">Daily Rate</span>
                    <span class="price-value">$200/night</span>
                </div>
                <div class="price-hour">
                    <span class="price-label">Hourly Rate</span>
                    <span class="price-value">$35/hour</span>
                </div>
            </div>

            <div class="contact-info">
                <h4>Contact</h4>
                <p>+250791375079</p>
                <p>info@grandhaven.com</p>
                <p>Kigali, Rwanda</p>
            </div>
        </div>

        <div class="booking-form-card">
            <h3>Book This Room</h3>

            <form method="post" id="bookingForm">
                <div class="booking-type-group">
                    <label>
                        <input type="radio" name="bookingType" value="daily" checked> Daily
                    </label>
                    <label>
                        <input type="radio" name="bookingType" value="hourly"> Hourly
                    </label>
                </div>

                <div class="form-group">
                    <label>Full Name</label>
                    <input type="text" name="fullName" placeholder="John Smith" required>
                </div>

                <div class="form-group">
                    <label>Email</label>
                    <input type="email" name="email" placeholder="john@email.com" required>
                </div>

                <div class="date-time-row">
                    <div class="form-group">
                        <label id="checkInLabel">Check-in Date</label>
                        <input type="date" name="checkInDate" id="checkInDate" required>
                    </div>
                    <div class="form-group">
                        <label id="checkOutLabel">Check-out Date</label>
                        <input type="date" name="checkOutDate" id="checkOutDate" required>
                    </div>
                </div>

                <div class="date-time-row" id="timeRow" style="display: none;">
                    <div class="form-group">
                        <label>Check-in Time</label>
                        <input type="time" name="checkInTime" value="14:00">
                    </div>
                    <div class="form-group">
                        <label>Check-out Time</label>
                        <input type="time" name="checkOutTime" value="12:00">
                    </div>
                </div>

                <div class="form-group">
                    <label>Guests</label>
                    <input type="number" name="guests" class="guests-input" value="1" min="1" max="3">
                    <small style="color:#999;">Max 3 guests</small>
                </div>

                <div class="total-price">
                    <span class="total-price-label">Total Price</span>
                    <span class="total-price-value" id="totalPrice">$0</span>
                </div>

                <button type="submit" class="btn-book">Confirm Booking →</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const priceNight = 200;
        const priceHour = 35;

        const bookingTypeRadios = document.querySelectorAll('input[name="bookingType"]');
        const checkInDate = document.getElementById('checkInDate');
        const checkOutDate = document.getElementById('checkOutDate');
        const checkInLabel = document.getElementById('checkInLabel');
        const checkOutLabel = document.getElementById('checkOutLabel');
        const timeRow = document.getElementById('timeRow');
        const totalPriceSpan = document.getElementById('totalPrice');

        const today = new Date().toISOString().split('T')[0];
        const tomorrow = new Date(Date.now() + 86400000).toISOString().split('T')[0];
        checkInDate.value = today;
        checkOutDate.value = tomorrow;

        function calculateTotal() {
            const bookingType = document.querySelector('input[name="bookingType"]:checked').value;
            const checkIn = new Date(checkInDate.value);
            const checkOut = new Date(checkOutDate.value);

            if (bookingType === 'daily') {
                const nights = Math.max(1, Math.ceil((checkOut - checkIn) / (1000 * 60 * 60 * 24)));
                totalPriceSpan.textContent = `$${nights * priceNight}`;
            } else {
                totalPriceSpan.textContent = `$${priceHour} (per hour)`;
            }
        }

        function toggleFields() {
            const bookingType = document.querySelector('input[name="bookingType"]:checked').value;
            if (bookingType === 'daily') {
                timeRow.style.display = 'none';
                checkOutDate.removeAttribute('disabled');
            } else {
                timeRow.style.display = 'flex';
                checkOutDate.disabled = true;
                checkOutDate.value = checkInDate.value;
            }
            calculateTotal();
        }

        bookingTypeRadios.forEach(radio => radio.addEventListener('change', toggleFields));
        checkInDate.addEventListener('change', () => {
            if (document.querySelector('input[name="bookingType"]:checked').value === 'hourly') {
                checkOutDate.value = checkInDate.value;
            }
            calculateTotal();
        });
        checkOutDate.addEventListener('change', calculateTotal);
        document.querySelector('input[name="checkInTime"]')?.addEventListener('change', calculateTotal);
        document.querySelector('input[name="checkOutTime"]')?.addEventListener('change', calculateTotal);

        toggleFields();
    </script>
}
