@page
@model HotelBookingSystem.Pages.Admin.DashboardModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"]      = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
}

<h1 class="staff-page-title">Dashboard</h1>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-card-top">
            <span class="stat-label">Total Bookings</span>
            <div class="stat-icon blue"><i class="fa-regular fa-calendar"></i></div>
        </div>
        <div class="stat-value">@Model.TotalBookings</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-top">
            <span class="stat-label">Total Rooms</span>
            <div class="stat-icon green"><i class="fa-solid fa-bed"></i></div>
        </div>
        <div class="stat-value">@Model.TotalRooms</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-top">
            <span class="stat-label">Total Revenue</span>
            <div class="stat-icon orange"><i class="fa-solid fa-dollar-sign"></i></div>
        </div>
        <div class="stat-value">$@Model.TotalRevenue.ToString("N0")</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-top">
            <span class="stat-label">Unread Messages</span>
            <div class="stat-icon yellow"><i class="fa-regular fa-envelope"></i></div>
        </div>
        <div class="stat-value">@Model.UnreadMessages</div>
    </div>
</div>

<div class="stats-grid" style="grid-template-columns: repeat(2,1fr)">
    <div class="stat-card">
        <div class="stat-card-top">
            <span class="stat-label">Total Events</span>
            <div class="stat-icon blue"><i class="fa-solid fa-calendar-days"></i></div>
        </div>
        <div class="stat-value">@Model.TotalEvents</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-top">
            <span class="stat-label">Contact Messages</span>
            <div class="stat-icon green"><i class="fa-solid fa-inbox"></i></div>
        </div>
        <div class="stat-value">@Model.TotalMessages</div>
    </div>
</div>

<div style="margin-top:32px; display:flex; gap:14px; flex-wrap:wrap;">
    <a href="/Admin/Rooms"    style="padding:11px 22px;background:#b07a2a;color:white;border-radius:8px;text-decoration:none;font-weight:600;font-size:14px;">Manage Rooms</a>
    <a href="/Admin/Bookings" style="padding:11px 22px;background:#1e140d;color:white;border-radius:8px;text-decoration:none;font-weight:600;font-size:14px;">View Bookings</a>
    <a href="/Admin/Messages" style="padding:11px 22px;background:#1e140d;color:white;border-radius:8px;text-decoration:none;font-weight:600;font-size:14px;">View Messages</a>
</div>
