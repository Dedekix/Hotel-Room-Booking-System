@page
@model HotelBookingSystem.Pages.Admin.RoomsModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"]      = "Rooms";
    ViewData["ActivePage"] = "Rooms";
}

<div class="rooms-mgmt-header">
    <h1 class="staff-page-title" style="margin-bottom:0">Rooms</h1>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="staff-alert @(Model.IsError ? "staff-alert-error" : "staff-alert-success")">@Model.Message</div>
}

<div class="rooms-mgmt-grid">
    @foreach (var room in Model.Rooms)
    {
        string badgeClass = room.IsOccupied  ? "badge-occupied"
                          : room.IsAvailable ? "badge-available"
                          : "badge-maintenance";
        string badgeText  = room.IsOccupied  ? "Occupied"
                          : room.IsAvailable ? "Available"
                          : "Maintenance";

        <div class="room-mgmt-card">
            <div class="room-mgmt-top">
                <span class="room-mgmt-name">Room @room.RoomNumber</span>
                <span class="@badgeClass">@badgeText</span>
            </div>
            <div class="room-mgmt-sub">@room.Type &middot; Max @room.Capacity Guests</div>
            <div class="room-mgmt-price">$@room.PricePerNight.ToString("0.##")/night</div>
            <div class="room-mgmt-actions">
                <form method="post" style="flex:1">
                    <input type="hidden" name="roomId"      value="@room.RoomId" />
                    <input type="hidden" name="isAvailable" value="@(!room.IsAvailable)" />
                    <button type="submit" class="btn-edit" style="width:100%">
                        @(room.IsAvailable ? "Mark Unavailable" : "Mark Available")
                    </button>
                </form>
                <button class="btn-key"><i class="fa-solid fa-screwdriver-wrench"></i></button>
            </div>
        </div>
    }
</div>
