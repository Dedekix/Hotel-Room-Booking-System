@page
@model HotelBookingSystem.Pages.Admin.RoomsModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"]      = "Rooms";
    ViewData["ActivePage"] = "Rooms";
}

<div class="rooms-mgmt-header">
    <h1 class="staff-page-title" style="margin-bottom:0">Rooms</h1>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="staff-alert @(Model.IsError ? "staff-alert-error" : "staff-alert-success")">@Model.Message</div>
}

<table class="bookings-table">
    <thead>
        <tr>
            <th>Room</th>
            <th>Type</th>
            <th>Price/Night</th>
            <th>Capacity</th>
            <th>Status</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var room in Model.Rooms)
        {
            <tr>
                <td><span class="guest-name">Room @room.RoomNumber</span></td>
                <td>@room.Type</td>
                <td class="total-amount">$@room.PricePerNight.ToString("0.##")</td>
                <td>@room.Capacity</td>
                <td>
                    @if (room.IsAvailable)
                    {
                        <span class="badge-available">Available</span>
                    }
                    else
                    {
                        <span class="badge-occupied">Unavailable</span>
                    }
                </td>
                <td>
                    <form method="post" style="display:inline">
                        <input type="hidden" name="roomId"      value="@room.RoomId" />
                        <input type="hidden" name="isAvailable" value="@(!room.IsAvailable)" />
                        <button type="submit" class="action-link">
                            @(room.IsAvailable ? "Mark Unavailable" : "Mark Available")
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
